<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinAware.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Ana Renkler -->
            <Color x:Key="Primary">#1AAFA3</Color>
            <Color x:Key="PrimaryDark">#0D7A71</Color>
            <Color x:Key="PrimaryLight">#E8F8F7</Color>
            <Color x:Key="Secondary">#1A1A2E</Color>
            <Color x:Key="Success">#4CAF50</Color>
            <Color x:Key="Danger">#F44336</Color>
            <Color x:Key="Warning">#FF9800</Color>
            <Color x:Key="Gray100">#F5F5F5</Color>
            <Color x:Key="Gray200">#EEEEEE</Color>
            <Color x:Key="Gray500">#9E9E9E</Color>
            <Color x:Key="Gray700">#616161</Color>
            <Color x:Key="White">#FFFFFF</Color>
            <Color x:Key="Black">#000000</Color>

            <!-- Stiller -->
            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="HeightRequest" Value="52" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{StaticResource Gray100}" />
                <Setter Property="TextColor" Value="{StaticResource Secondary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource Gray500}" />
                <Setter Property="HeightRequest" Value="52" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="Margin" Value="0,4" />
            </Style>

            <Style TargetType="Label" x:Key="TitleLabel">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource Secondary}" />
            </Style>

            <Style TargetType="Label" x:Key="SubtitleLabel">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource Gray500}" />
            </Style>

            <Style TargetType="Frame">
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="BorderColor" Value="Transparent" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="BackgroundColor" Value="White" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>