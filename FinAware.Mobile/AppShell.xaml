<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:FinAware.Mobile.Views"
       x:Class="FinAware.Mobile.AppShell"
       Shell.NavBarIsVisible="False">

    <TabBar>
        <ShellContent Title="Ana Sayfa"
                      Icon="icon_dashboard.png"
                      ContentTemplate="{DataTemplate views:DashboardPage}" />
        <ShellContent Title="İşlemler"
                      Icon="icon_transaction.png"
                      ContentTemplate="{DataTemplate views:TransactionPage}" />
        <ShellContent Title="Bütçe"
                      Icon="icon_budget.png"
                      ContentTemplate="{DataTemplate views:BudgetPage}" />
        <ShellContent Title="Birikim"
                      Icon="icon_saving.png"
                      ContentTemplate="{DataTemplate views:SavingPage}" />
        <ShellContent Title="Profil"
                      Icon="icon_profile.png"
                      ContentTemplate="{DataTemplate views:ProfilePage}" />
    </TabBar>
</Shell>