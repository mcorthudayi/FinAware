<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FinAware.Mobile.ViewModels"
             xmlns:models="clr-namespace:FinAware.Mobile.Models"
             x:Class="FinAware.Mobile.Views.BudgetPage"
             x:DataType="vm:BudgetViewModel"
             BackgroundColor="#F5F5F5"
             Title="Bütçe">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Yeni Bütçe Formu -->
            <Frame BackgroundColor="White" CornerRadius="16" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Yeni Bütçe" FontSize="16"
                           FontAttributes="Bold" TextColor="#1A1A2E"/>

                    <Picker Title="Kategori (opsiyonel)"
                            ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding SelectedCategory}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            TextColor="#1A1A2E"/>

                    <Border Stroke="#E0E0E0" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10">
                        <Entry Placeholder="Limit tutarı (₺)"
                               Text="{Binding LimitAmount, StringFormat='{0}'}"
                               Keyboard="Numeric"
                               BackgroundColor="Transparent"
                               Margin="12,0"/>
                    </Border>

                    <Button Text="Bütçe Ekle"
                            Command="{Binding AddBudgetCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            HeightRequest="46"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Bütçe Listesi -->
            <Label Text="Mevcut Bütçeler" FontSize="18"
                   FontAttributes="Bold" TextColor="#1A1A2E"/>

            <CollectionView ItemsSource="{Binding Budgets}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:BudgetModel">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Sil"
                                               BackgroundColor="#F44336"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BudgetViewModel}}, Path=DeleteBudgetCommand}"
                                               CommandParameter="{Binding}"/>
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Frame Margin="0,4" Padding="16"
                                   CornerRadius="16" HasShadow="False"
                                   BackgroundColor="White">
                                <VerticalStackLayout Spacing="8">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding CategoryIcon}"
                                               FontSize="20"/>
                                        <Label Text="{Binding CategoryName}"
                                               FontSize="16" FontAttributes="Bold"
                                               TextColor="#1A1A2E"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <ProgressBar Progress="{Binding Progress}"
                                                 ProgressColor="{Binding ProgressColor}"/>

                                    <Label Text="{Binding ProgressDisplay}"
                                           FontSize="13" TextColor="#616161"/>
                                </VerticalStackLayout>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" Margin="0,32">
                        <Label Text="📊" FontSize="48"
                               HorizontalOptions="Center"/>
                        <Label Text="Henüz bütçe yok"
                               FontSize="16" TextColor="#9E9E9E"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>