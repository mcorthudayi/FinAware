<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FinAware.Mobile.ViewModels"
             xmlns:models="clr-namespace:FinAware.Mobile.Models"
             x:Class="FinAware.Mobile.Views.CategoryPage"
             x:DataType="vm:CategoryViewModel"
             BackgroundColor="#F5F5F5"
             Title="Kategoriler">

    <Grid RowDefinitions="Auto,*">

        <Frame Grid.Row="0" Margin="16,16,16,8"
               CornerRadius="16" Padding="16"
               BackgroundColor="White">
            <VerticalStackLayout Spacing="10">
                <Label Text="Yeni Kategori" FontSize="16"
                       FontAttributes="Bold" TextColor="#1A1A2E"/>

                <Border Stroke="#E0E0E0" StrokeThickness="1"
                        StrokeShape="RoundRectangle 10">
                    <Entry Placeholder="Kategori adı"
                           Text="{Binding Name}"
                           BackgroundColor="Transparent"
                           Margin="12,0"/>
                </Border>

                <Picker Title="Tür seçin"
                        ItemsSource="{Binding Types}"
                        SelectedItem="{Binding SelectedType}"
                        TextColor="#1A1A2E"/>

                <Label Text="İkon seç:" FontSize="13" TextColor="#616161"/>
                <CollectionView ItemsSource="{Binding Icons}"
                                SelectedItem="{Binding SelectedIcon}"
                                SelectionMode="Single"
                                HeightRequest="56">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal"
                                           ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Frame Padding="6" CornerRadius="8"
                                   BackgroundColor="#E8F8F7">
                                <Label Text="{Binding}" FontSize="22"
                                       HorizontalOptions="Center"/>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="Kategori Ekle"
                        Command="{Binding AddCategoryCommand}"
                        IsEnabled="{Binding IsNotBusy}"
                        HeightRequest="46"/>
            </VerticalStackLayout>
        </Frame>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Categories}"
                        Margin="16,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CategoryModel">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Sil"
                                           BackgroundColor="#F44336"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoryViewModel}}, Path=DeleteCategoryCommand}"
                                           CommandParameter="{Binding}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Frame Margin="0,4" Padding="14"
                               CornerRadius="14" HasShadow="False"
                               BackgroundColor="White">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="{Binding Icon}" FontSize="24"
                                       VerticalOptions="Center"/>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="#1A1A2E"/>
                                    <Label Text="{Binding Type}"
                                           FontSize="12" TextColor="#9E9E9E"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>