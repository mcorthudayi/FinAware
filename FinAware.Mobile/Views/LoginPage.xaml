<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FinAware.Mobile.ViewModels"
             x:Class="FinAware.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!-- Logo ve Başlık -->
            <Label Text="💰" FontSize="64"
                   HorizontalOptions="Center"
                   Margin="0,0,0,16"/>

            <Label Text="FinAware"
                   FontSize="36" FontAttributes="Bold"
                   TextColor="#1AAFA3"
                   HorizontalOptions="Center"/>

            <Label Text="Finansal özgürlüğünüz için"
                   FontSize="14" TextColor="#9E9E9E"
                   HorizontalOptions="Center"
                   Margin="0,4,0,48"/>

            <!-- Hata Mesajı -->
            <Frame IsVisible="{Binding HasError}"
                   BackgroundColor="#FFEBEE"
                   BorderColor="#F44336"
                   CornerRadius="12"
                   Padding="12"
                   Margin="0,0,0,16">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#F44336"
                       FontSize="14"/>
            </Frame>

            <!-- E-posta -->
            <Label Text="E-posta" FontSize="13"
                   TextColor="#616161" FontAttributes="Bold"
                   Margin="0,0,0,4"/>
            <Border Stroke="#E0E0E0" StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12"
                    Margin="0,0,0,16">
                <Entry Placeholder="ornek@email.com"
                       Text="{Binding Email}"
                       Keyboard="Email"
                       BackgroundColor="Transparent"
                       Margin="12,0"/>
            </Border>

            <!-- Şifre -->
            <Label Text="Şifre" FontSize="13"
                   TextColor="#616161" FontAttributes="Bold"
                   Margin="0,0,0,4"/>
            <Border Stroke="#E0E0E0" StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12"
                    Margin="0,0,0,24">
                <Entry Placeholder="••••••••"
                       Text="{Binding Password}"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       Margin="12,0"/>
            </Border>

            <!-- Giriş Butonu -->
            <Button Text="Giriş Yap"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    Margin="0,0,0,16"/>

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#1AAFA3"
                               HorizontalOptions="Center"
                               Margin="0,0,0,16"/>

            <!-- Kayıt Ol -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Hesabın yok mu?"
                       TextColor="#9E9E9E" FontSize="14"
                       VerticalOptions="Center"/>
                <Label Text="Kayıt Ol"
                       TextColor="#1AAFA3" FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding GoToRegisterCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>