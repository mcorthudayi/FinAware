<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FinAware.Mobile.ViewModels"
             x:Class="FinAware.Mobile.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             BackgroundColor="#F5F5F5"
             Title="Profil">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Profil Kartı -->
            <Frame BackgroundColor="#1AAFA3"
                   CornerRadius="20" Padding="24">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Label Text="👤" FontSize="56"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding Username}"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding Email}"
                           FontSize="14" TextColor="White"
                           Opacity="0.85"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Şifre Değiştir -->
            <Frame BackgroundColor="White" CornerRadius="16" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🔒 Şifre Değiştir" FontSize="16"
                           FontAttributes="Bold" TextColor="#1A1A2E"/>

                    <Border Stroke="#E0E0E0" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10">
                        <Entry Placeholder="Mevcut şifre"
                               Text="{Binding CurrentPassword}"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               Margin="12,0"/>
                    </Border>

                    <Border Stroke="#E0E0E0" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10">
                        <Entry Placeholder="Yeni şifre"
                               Text="{Binding NewPassword}"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               Margin="12,0"/>
                    </Border>

                    <Border Stroke="#E0E0E0" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10">
                        <Entry Placeholder="Yeni şifre tekrar"
                               Text="{Binding ConfirmNewPassword}"
                               IsPassword="True"
                               BackgroundColor="Transparent"
                               Margin="12,0"/>
                    </Border>

                    <Button Text="Şifreyi Değiştir"
                            Command="{Binding ChangePasswordCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            HeightRequest="46"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Ayarlar -->
            <Frame BackgroundColor="White" CornerRadius="16" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="⚙️ Ayarlar" FontSize="16"
                           FontAttributes="Bold" TextColor="#1A1A2E"/>

                    <HorizontalStackLayout>
                        <Label Text="E-posta Bildirimleri"
                               FontSize="15" TextColor="#1A1A2E"
                               VerticalOptions="Center"
                               HorizontalOptions="FillAndExpand"/>
                        <Switch IsToggled="{Binding EmailNotificationsEnabled}"
                                OnColor="#1AAFA3"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout>
                        <Label Text="Telegram Bağlı"
                               FontSize="15" TextColor="#1A1A2E"
                               VerticalOptions="Center"
                               HorizontalOptions="FillAndExpand"/>
                        <Label Text="{Binding TelegramLinked, StringFormat='{0}'}"
                               FontSize="14" TextColor="#9E9E9E"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Çıkış Yap -->
            <Button Text="Çıkış Yap"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="#F44336"
                    Margin="0,8"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#1AAFA3"
                               HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>