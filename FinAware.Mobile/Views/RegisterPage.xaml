<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FinAware.Mobile.ViewModels"
             x:Class="FinAware.Mobile.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <Label Text="Hesap Oluştur"
                   Style="{StaticResource TitleLabel}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8"/>

            <Label Text="FinAware'e hoş geldiniz!"
                   Style="{StaticResource SubtitleLabel}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,40"/>

            <!-- Hata -->
            <Frame IsVisible="{Binding HasError}"
                   BackgroundColor="#FFEBEE"
                   BorderColor="#F44336"
                   CornerRadius="12" Padding="12"
                   Margin="0,0,0,16">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#F44336" FontSize="14"/>
            </Frame>

            <!-- Başarı -->
            <Frame IsVisible="{Binding HasSuccess}"
                   BackgroundColor="#E8F5E9"
                   BorderColor="#4CAF50"
                   CornerRadius="12" Padding="12"
                   Margin="0,0,0,16">
                <Label Text="{Binding SuccessMessage}"
                       TextColor="#4CAF50" FontSize="14"/>
            </Frame>

            <Label Text="Kullanıcı Adı" FontSize="13"
                   TextColor="#616161" FontAttributes="Bold"
                   Margin="0,0,0,4"/>
            <Border Stroke="#E0E0E0" StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12"
                    Margin="0,0,0,16">
                <Entry Placeholder="kullanici_adi"
                       Text="{Binding Username}"
                       BackgroundColor="Transparent"
                       Margin="12,0"/>
            </Border>

            <Label Text="E-posta" FontSize="13"
                   TextColor="#616161" FontAttributes="Bold"
                   Margin="0,0,0,4"/>
            <Border Stroke="#E0E0E0" StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12"
                    Margin="0,0,0,16">
                <Entry Placeholder="ornek@email.com"
                       Text="{Binding Email}"
                       Keyboard="Email"
                       BackgroundColor="Transparent"
                       Margin="12,0"/>
            </Border>

            <Label Text="Şifre" FontSize="13"
                   TextColor="#616161" FontAttributes="Bold"
                   Margin="0,0,0,4"/>
            <Border Stroke="#E0E0E0" StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12"
                    Margin="0,0,0,16">
                <Entry Placeholder="••••••••"
                       Text="{Binding Password}"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       Margin="12,0"/>
            </Border>

            <Label Text="Şifre Tekrar" FontSize="13"
                   TextColor="#616161" FontAttributes="Bold"
                   Margin="0,0,0,4"/>
            <Border Stroke="#E0E0E0" StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 12"
                    Margin="0,0,0,24">
                <Entry Placeholder="••••••••"
                       Text="{Binding ConfirmPassword}"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       Margin="12,0"/>
            </Border>

            <Button Text="Kayıt Ol"
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    Margin="0,0,0,16"/>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#1AAFA3"
                               HorizontalOptions="Center"/>

            <HorizontalStackLayout HorizontalOptions="Center"
                                   Spacing="4" Margin="0,16,0,0">
                <Label Text="Zaten hesabın var mı?"
                       TextColor="#9E9E9E" FontSize="14"
                       VerticalOptions="Center"/>
                <Label Text="Giriş Yap"
                       TextColor="#1AAFA3" FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding GoBackCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>