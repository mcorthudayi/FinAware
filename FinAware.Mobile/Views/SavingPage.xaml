<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FinAware.Mobile.ViewModels"
             xmlns:models="clr-namespace:FinAware.Mobile.Models"
             x:Class="FinAware.Mobile.Views.SavingPage"
             x:DataType="vm:SavingViewModel"
             BackgroundColor="#F5F5F5"
             Title="Birikimler">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Yeni Birikim Formu -->
            <Frame BackgroundColor="White" CornerRadius="16" Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Yeni Birikim Hedefi" FontSize="16"
                           FontAttributes="Bold" TextColor="#1A1A2E"/>

                    <Border Stroke="#E0E0E0" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10">
                        <Entry Placeholder="Hedef adı (örn. Tatil Fonu)"
                               Text="{Binding GoalName}"
                               BackgroundColor="Transparent"
                               Margin="12,0"/>
                    </Border>

                    <Border Stroke="#E0E0E0" StrokeThickness="1"
                            StrokeShape="RoundRectangle 10">
                        <Entry Placeholder="Hedef tutar (₺)"
                               Text="{Binding TargetAmount}"
                               Keyboard="Numeric"
                               BackgroundColor="Transparent"
                               Margin="12,0"/>
                    </Border>

                    <!-- İkon Seçimi -->
                    <Label Text="İkon seç:" FontSize="13"
                           TextColor="#616161"/>
                    <CollectionView ItemsSource="{Binding Icons}"
                                    SelectedItem="{Binding SelectedIcon}"
                                    SelectionMode="Single"
                                    HeightRequest="60">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="8"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Frame Padding="8" CornerRadius="10"
                                       BackgroundColor="#E8F8F7">
                                    <Label Text="{Binding}"
                                           FontSize="24"
                                           HorizontalOptions="Center"/>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Text="Hedef Ekle"
                            Command="{Binding AddSavingCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            HeightRequest="46"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Birikim Listesi -->
            <Label Text="Birikimlerim" FontSize="18"
                   FontAttributes="Bold" TextColor="#1A1A2E"/>

            <CollectionView ItemsSource="{Binding Savings}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SavingModel">
                        <Frame Margin="0,4" Padding="16"
                               CornerRadius="16" HasShadow="False"
                               BackgroundColor="White">
                            <VerticalStackLayout Spacing="10">
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding Icon}" FontSize="28"/>
                                    <VerticalStackLayout VerticalOptions="Center">
                                        <Label Text="{Binding GoalName}"
                                               FontSize="16" FontAttributes="Bold"
                                               TextColor="#1A1A2E"/>
                                        <Label Text="{Binding TargetDateDisplay}"
                                               FontSize="12" TextColor="#9E9E9E"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>

                                <ProgressBar Progress="{Binding ProgressValue}"
                                             ProgressColor="#1AAFA3"/>

                                <Label Text="{Binding ProgressDisplay}"
                                       FontSize="13" TextColor="#616161"/>

                                <HorizontalStackLayout Spacing="8">
                                    <Button Text="+ Para Ekle"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SavingViewModel}}, Path=AddAmountCommand}"
                                            CommandParameter="{Binding}"
                                            BackgroundColor="#1AAFA3"
                                            HeightRequest="36"
                                            FontSize="13"
                                            HorizontalOptions="FillAndExpand"/>
                                    <Button Text="Sil"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SavingViewModel}}, Path=DeleteSavingCommand}"
                                            CommandParameter="{Binding}"
                                            BackgroundColor="#F44336"
                                            HeightRequest="36"
                                            FontSize="13"
                                            WidthRequest="60"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" Margin="0,32">
                        <Label Text="💰" FontSize="48"
                               HorizontalOptions="Center"/>
                        <Label Text="Henüz birikim hedefi yok"
                               FontSize="16" TextColor="#9E9E9E"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>