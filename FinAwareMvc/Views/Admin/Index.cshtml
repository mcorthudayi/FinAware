@{
    ViewData["Title"] = "Admin Paneli";
    var stats = ViewBag.Stats;
    var users = ViewBag.Users as List<dynamic> ?? new List<dynamic>();
}

<div class="container-fluid py-4">
    <h2 class="mb-4">🛡️ Admin Paneli</h2>

 
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-1">👥</div>
                <div class="fs-3 fw-bold text-primary">@stats?.totalUsers</div>
                <div class="text-muted">Toplam Kullanıcı</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-1">✅</div>
                <div class="fs-3 fw-bold text-success">@stats?.verifiedUsers</div>
                <div class="text-muted">Doğrulanmış</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-1">💳</div>
                <div class="fs-3 fw-bold text-warning">@stats?.totalTransactions</div>
                <div class="text-muted">Toplam İşlem</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-1">🤖</div>
                <div class="fs-3 fw-bold text-info">@stats?.telegramLinked</div>
                <div class="text-muted">Telegram Bağlı</div>
            </div>
        </div>
    </div>


    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-bold">👤 Kullanıcılar</div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Kullanıcı</th>
                        <th>Email</th>
                        <th>Rol</th>
                        <th>Durum</th>
                        <th>İşlem Sayısı</th>
                        <th>Kayıt</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        <tr>
                            <td>@user.userId</td>
                            <td><strong>@user.username</strong></td>
                            <td>@user.email</td>
                            <td>
                                @if (user.role == "Admin")
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else if (user.role == "Frozen")
                                {
                                    <span class="badge bg-secondary">Dondurulmuş</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">User</span>
                                }
                            </td>
                            <td>
                                @if (user.isEmailVerified == true)
                                {
                                    <span class="text-success">✅ Doğrulandı</span>
                                }
                                else
                                {
                                    <span class="text-warning">⏳ Bekliyor</span>
                                }
                            </td>
                            <td>@user.transactionCount</td>
                            <td>@(((DateTime)user.createdAt).ToString("dd.MM.yyyy"))</td>
                            <td>
                                @if (user.role != "Admin")
                                {
                                    if (user.role == "Frozen")
                                    {
                                        <form method="post" asp-action="UnfreezeUser" class="d-inline">
                                            <input type="hidden" name="id" value="@user.userId" />
                                            <button class="btn btn-sm btn-success">▶ Aktif Et</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form method="post" asp-action="FreezeUser" class="d-inline">
                                            <input type="hidden" name="id" value="@user.userId" />
                                            <button class="btn btn-sm btn-warning">❄ Dondur</button>
                                        </form>
                                    }
                                    <form method="post" asp-action="DeleteUser" class="d-inline"
                                          onsubmit="return confirm('@user.username kullanıcısını silmek istediğinize emin misiniz?')">
                                        <input type="hidden" name="id" value="@user.userId" />
                                        <button class="btn btn-sm btn-danger">🗑 Sil</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>