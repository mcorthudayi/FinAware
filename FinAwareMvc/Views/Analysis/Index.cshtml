@using FinAware.MVC.Models.ViewModels
@model AnalysisViewModel
@{
    ViewData["Title"] = "Analiz";
    var culture = new System.Globalization.CultureInfo("tr-TR");
}

<style>
    .filter-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        padding: 16px 20px;
        margin-bottom: 20px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
    }

    .period-btn {
        padding: 8px 16px;
        border-radius: 10px;
        border: 1.5px solid #e5e7eb;
        background: white;
        font-size: 13px;
        font-weight: 500;
        color: #374151;
        text-decoration: none;
        transition: all 0.18s;
    }

    .period-btn.active {
        background: linear-gradient(135deg, #1AAFA3 0%, #0D7A71 100%);
        border-color: #1AAFA3;
        color: white;
    }

    .period-btn:hover:not(.active) {
        border-color: #1AAFA3;
        color: #1AAFA3;
    }

    .stat-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .stat-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px; flex-shrink: 0;
    }

    .chart-card {
        background: white;
        border-radius: 14px;
        border: 1px solid #e5e7eb;
        padding: 20px;
    }

    .firm-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #f3f4f6;
        gap: 12px;
    }

    .firm-item:last-child { border-bottom: none; }

    .firm-bar-bg {
        flex: 1;
        height: 6px;
        background: #f3f4f6;
        border-radius: 3px;
        overflow: hidden;
    }

    .firm-bar-fill {
        height: 100%;
        background: linear-gradient(135deg, #1AAFA3, #0D7A71);
        border-radius: 3px;
        transition: width 0.5s ease;
    }

    .filter-select {
        padding: 8px 12px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 13px;
        color: #374151;
        background: white;
        cursor: pointer;
    }

    .filter-select:focus {
        outline: none;
        border-color: #1AAFA3;
        box-shadow: 0 0 0 3px rgba(26,175,163,0.1);
    }

    .search-input {
        padding: 8px 12px 8px 34px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 13px;
        color: #374151;
        background: white;
        width: 200px;
    }

    .search-input:focus {
        outline: none;
        border-color: #1AAFA3;
        box-shadow: 0 0 0 3px rgba(26,175,163,0.1);
    }

    .export-btn {
        padding: 8px 16px;
        border-radius: 10px;
        background: #f0fdf4;
        border: 1.5px solid #1AAFA3;
        color: #0D7A71;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.18s;
        margin-left: auto;
    }

    .export-btn:hover {
        background: #1AAFA3;
        color: white;
    }

    .tx-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 10px;
        margin-bottom: 4px;
        transition: background 0.15s;
    }

    .tx-row:hover { background: #f9fafb; }

    .tx-icon {
        width: 38px; height: 38px;
        border-radius: 9px;
        background: #f3f4f6;
        display: flex; align-items: center; justify-content: center;
        font-size: 17px; flex-shrink: 0;
    }

    .badge-income { background: #ecfdf5; color: #065f46; padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .badge-expense { background: #fef2f2; color: #991b1b; padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
</style>

<!-- Sayfa Başlığı + Export -->
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="display-6 fw-bold mb-1">Analiz & İstatistikler</h1>
        <p class="text-muted mb-0">Gelir, gider ve harcama analizleriniz</p>
    </div>
    <a href="/Transaction/Export?period=@Model.Period" class="export-btn">
        <i class="bi bi-file-earmark-excel"></i>Excel İndir
    </a>
</div>

<!-- Period Filtre + Kategori Filtre -->
<div class="filter-card">
    <div class="d-flex gap-2 flex-wrap">
        <a href="/Analysis/Index?period=weekly"  class="period-btn @(Model.Period == "weekly"  ? "active" : "")">
            <i class="bi bi-calendar-week me-1"></i>Haftalık
        </a>
        <a href="/Analysis/Index?period=monthly" class="period-btn @(Model.Period == "monthly" ? "active" : "")">
            <i class="bi bi-calendar-month me-1"></i>Aylık
        </a>
        <a href="/Analysis/Index?period=6months" class="period-btn @(Model.Period == "6months" ? "active" : "")">
            <i class="bi bi-calendar-range me-1"></i>6 Aylık
        </a>
        <a href="/Analysis/Index?period=yearly"  class="period-btn @(Model.Period == "yearly"  ? "active" : "")">
            <i class="bi bi-calendar4 me-1"></i>Yıllık
        </a>
    </div>

    <div style="width: 1px; height: 30px; background: #e5e7eb; margin: 0 4px;"></div>

    <!-- Kategori filtre -->
    <select class="filter-select" id="categoryFilter" onchange="filterTable()">
        <option value="">Tüm Kategoriler</option>
        @if (Model.Transactions != null)
        {
            foreach (var cat in Model.Transactions
                .GroupBy(t => t.CategoryName)
                .OrderBy(g => g.Key))
            {
                <option value="@cat.Key">@(Model.Transactions.FirstOrDefault(t => t.CategoryName == cat.Key)?.CategoryIcon) @cat.Key</option>
            }
        }
    </select>

    <!-- Tip filtre -->
    <select class="filter-select" id="typeFilter" onchange="filterTable()">
        <option value="">Gelir & Gider</option>
        <option value="Income">💰 Sadece Gelir</option>
        <option value="Expense">💸 Sadece Gider</option>
    </select>

    <!-- Arama -->
    <div style="position: relative;">
        <i class="bi bi-search" style="position:absolute; left:10px; top:50%; transform:translateY(-50%); color:#9ca3af; font-size:13px;"></i>
        <input type="text" class="search-input" id="searchFilter"
               placeholder="İşlem ara..." oninput="filterTable()" />
    </div>
</div>

<!-- Özet Kartlar -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <div style="font-size:12px; color:#6b7280; margin-bottom:4px;">Toplam Gelir</div>
                <div style="font-size:24px; font-weight:700; color:#10b981;">₺@Model.TotalIncome.ToString("N2")</div>
            </div>
            <div class="stat-icon" style="background:#ecfdf5;">
                <i class="bi bi-arrow-down-circle" style="color:#10b981;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <div style="font-size:12px; color:#6b7280; margin-bottom:4px;">Toplam Gider</div>
                <div style="font-size:24px; font-weight:700; color:#ef4444;">₺@Model.TotalExpenses.ToString("N2")</div>
            </div>
            <div class="stat-icon" style="background:#fef2f2;">
                <i class="bi bi-arrow-up-circle" style="color:#ef4444;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <div style="font-size:12px; color:#6b7280; margin-bottom:4px;">Net Bakiye</div>
                <div style="font-size:24px; font-weight:700; color:@(Model.Balance >= 0 ? "#1AAFA3" : "#ef4444");">
                    ₺@Model.Balance.ToString("N2")
                </div>
            </div>
            <div class="stat-icon" style="background:#f0fdf4;">
                <i class="bi bi-wallet2" style="color:#1AAFA3;"></i>
            </div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="chart-card">
            <h6 class="fw-bold mb-3">📊 Gelir vs Gider</h6>
            <div style="height: 280px; position: relative;">
                <canvas id="incomeExpenseChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="chart-card">
            <h6 class="fw-bold mb-3">🏷️ Kategori Bazlı Harcamalar</h6>
            @if (Model.CategoryExpenses != null && Model.CategoryExpenses.Any())
            {
                <div style="height: 280px; position: relative;">
                    <canvas id="categoryChart"></canvas>
                </div>
            }
            else
            {
                <div style="height: 280px; display:flex; align-items:center; justify-content:center;">
                    <p class="text-muted">Bu dönemde gider yok</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Firma Bazlı Harcamalar -->
@if (Model.Transactions != null && Model.Transactions.Any(t => t.Type == "Expense" && !string.IsNullOrEmpty(t.Description)))
{
    var firmGroups = Model.Transactions
        .Where(t => t.Type == "Expense" && !string.IsNullOrEmpty(t.Description))
        .GroupBy(t => t.Description!.Trim())
        .Select(g => new { Name = g.Key, Total = g.Sum(t => t.Amount), Count = g.Count() })
        .OrderByDescending(g => g.Total)
        .Take(10)
        .ToList();

    if (firmGroups.Any())
    {
        decimal maxFirm = firmGroups.Max(f => f.Total);

        <div class="chart-card mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">🏢 Firma / Açıklama Bazlı Harcamalar</h6>
                <span style="font-size:12px; color:#9ca3af;">Top 10</span>
            </div>

            @foreach (var firm in firmGroups)
            {
                double pct = maxFirm > 0 ? (double)(firm.Total / maxFirm * 100) : 0;
                double totalPct = Model.TotalExpenses > 0
                    ? (double)(firm.Total / Model.TotalExpenses * 100) : 0;

                <div class="firm-item">
                    <div style="min-width:180px; max-width:220px;">
                        <div style="font-weight:600; font-size:13px; color:#111827;
                                    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            @firm.Name
                        </div>
                        <div style="font-size:11px; color:#9ca3af;">@firm.Count işlem · %@totalPct.ToString("N1") toplam</div>
                    </div>
                    <div class="firm-bar-bg">
                        <div class="firm-bar-fill" style="width: @pct.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <div style="font-weight:700; color:#ef4444; font-size:13px; min-width:90px; text-align:right;">
                        ₺@firm.Total.ToString("N2")
                    </div>
                </div>
            }
        </div>
    }
}

<!-- İşlem Geçmişi -->
<div class="chart-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="fw-bold mb-0">📋 İşlem Geçmişi</h6>
        <span id="txCount" style="font-size:12px; color:#9ca3af;"></span>
    </div>

    @if (Model.Transactions != null && Model.Transactions.Any())
    {
        <div id="transactionList">
            @foreach (var t in Model.Transactions.OrderByDescending(t => t.Date))
            {
                <div class="tx-row"
                     data-type="@t.Type"
                     data-category="@t.CategoryName"
                     data-search="@((t.Description + " " + t.CategoryName).ToLower())">
                    <div class="tx-icon">@(t.CategoryIcon ?? "💳")</div>
                    <div style="flex:1; min-width:0;">
                        <div style="font-weight:600; font-size:13px; color:#111827;
                                    white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                            @(string.IsNullOrEmpty(t.Description) ? t.CategoryName : t.Description)
                        </div>
                        <div style="font-size:11px; color:#9ca3af;">
                            @t.Date.ToString("dd MMM yyyy", culture) · @t.CategoryName
                        </div>
                    </div>
                    <span class="@(t.Type == "Income" ? "badge-income" : "badge-expense")">
                        @(t.Type == "Income" ? "Gelir" : "Gider")
                    </span>
                    <div style="font-weight:700; font-size:14px; min-width:90px; text-align:right;
                                color:@(t.Type == "Income" ? "#10b981" : "#ef4444");">
                        @(t.Type == "Income" ? "+" : "-")₺@t.Amount.ToString("N2")
                    </div>
                </div>
            }
        </div>
        <div id="emptyFilter" style="display:none; text-align:center; padding:32px; color:#9ca3af;">
            <i class="bi bi-search" style="font-size:32px; display:block; margin-bottom:8px;"></i>
            Filtre sonucu bulunamadı
        </div>
    }
    else
    {
        <div style="text-align:center; padding:48px; color:#9ca3af;">
            <i class="bi bi-inbox" style="font-size:48px; display:block; margin-bottom:12px;"></i>
            Bu dönemde işlem yok
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // ── Chartlar ────────────────────────────────────────────────
        const incomeValue  = @Model.TotalIncome.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const expenseValue = @Model.TotalExpenses.ToString(System.Globalization.CultureInfo.InvariantCulture);

        new Chart(document.getElementById('incomeExpenseChart'), {
            type: 'bar',
            data: {
                labels: ['Gelir', 'Gider'],
                datasets: [{
                    data: [incomeValue, expenseValue],
                    backgroundColor: ['#10b981', '#ef4444'],
                    borderRadius: 10,
                    barThickness: 60
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false },
                    tooltip: { callbacks: { label: ctx =>
                        '₺' + ctx.parsed.y.toLocaleString('tr-TR', {minimumFractionDigits:2}) } } },
                scales: { y: { beginAtZero: true,
                    ticks: { callback: v => '₺' + v.toLocaleString('tr-TR') } } }
            }
        });

        @if (Model.CategoryExpenses != null && Model.CategoryExpenses.Any())
        {
            <text>
            const catData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
                labels = Model.CategoryExpenses.Keys.ToArray(),
                values = Model.CategoryExpenses.Values.Select(v => decimal.ToDouble(v)).ToArray()
            }));

            new Chart(document.getElementById('categoryChart'), {
                type: 'doughnut',
                data: {
                    labels: catData.labels,
                    datasets: [{
                        data: catData.values,
                        backgroundColor: ['#1AAFA3','#ef4444','#3b82f6','#8b5cf6',
                                          '#f59e0b','#ec4899','#06b6d4','#84cc16',
                                          '#f97316','#6366f1']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 12, font: { size: 11 } } },
                        tooltip: { callbacks: { label: ctx =>
                            ctx.label + ': ₺' + ctx.parsed.toLocaleString('tr-TR', {minimumFractionDigits:2}) } }
                    }
                }
            });
            </text>
        }

        // ── Filtre ──────────────────────────────────────────────────
        function filterTable() {
            const cat    = document.getElementById('categoryFilter').value;
            const type   = document.getElementById('typeFilter').value;
            const search = document.getElementById('searchFilter').value.toLowerCase();

            const rows = document.querySelectorAll('.tx-row');
            let visible = 0;

            rows.forEach(row => {
                const catMatch    = !cat    || row.dataset.category === cat;
                const typeMatch   = !type   || row.dataset.type     === type;
                const searchMatch = !search || row.dataset.search.includes(search);
                const show = catMatch && typeMatch && searchMatch;
                row.style.display = show ? 'flex' : 'none';
                if (show) visible++;
            });

            document.getElementById('txCount').textContent = visible + ' işlem';
            const empty = document.getElementById('emptyFilter');
            if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
        }

        // Sayfa yüklenince count'u set et
        document.addEventListener('DOMContentLoaded', () => {
            const rows = document.querySelectorAll('.tx-row');
            document.getElementById('txCount').textContent = rows.length + ' işlem';
        });
    </script>
}