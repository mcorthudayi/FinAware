@using FinAware.MVC.Models.ViewModels
@using FinAware.MVC.Models
@model DashboardViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
    var culture = new System.Globalization.CultureInfo("tr-TR");
}

<div class="mb-4">
    <h1 class="display-6 fw-bold">Merhaba, @(Context.Session.GetString("Username") ?? "Kullanıcı")! 👋</h1>
    <p class="text-muted">Bugün @DateTime.Now.ToString("dd MMMM yyyy, dddd", culture)</p>
</div>

<!-- Özet Kartlar -->
<div class="row mb-4">

    <!-- Toplam Gelir — tıklanabilir -->
    <div class="col-md-4 mb-3">
        <div class="card"
             onclick="window.location.href='/Transaction/Create?type=Income'"
             style="border-radius:14px; box-shadow:0 2px 8px rgba(0,0,0,0.08);
                    border-left:4px solid #10b981; cursor:pointer; transition:all 0.2s;"
             onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.12)'"
             onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)'">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1" style="font-size:13px;">Toplam Gelir</p>
                        <h3 class="fw-bold mb-0" style="color:#10b981;">+₺@Model.TotalIncome.ToString("N2", culture)</h3>
                        <small style="color:#9ca3af;font-size:11px;">Gelir eklemek için tıkla</small>
                    </div>
                    <div style="width:56px;height:56px;background:#ecfdf5;border-radius:14px;
                                display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-arrow-down-circle" style="font-size:28px;color:#10b981;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toplam Gider — tıklanabilir -->
    <div class="col-md-4 mb-3">
        <div class="card"
             onclick="window.location.href='/Transaction/Create?type=Expense'"
             style="border-radius:14px; box-shadow:0 2px 8px rgba(0,0,0,0.08);
                    border-left:4px solid #ef4444; cursor:pointer; transition:all 0.2s;"
             onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.12)'"
             onmouseout="this.style.transform='';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)'">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1" style="font-size:13px;">Toplam Gider</p>
                        <h3 class="fw-bold mb-0" style="color:#ef4444;">-₺@Model.TotalExpense.ToString("N2", culture)</h3>
                        <small style="color:#9ca3af;font-size:11px;">Gider eklemek için tıkla</small>
                    </div>
                    <div style="width:56px;height:56px;background:#fef2f2;border-radius:14px;
                                display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-arrow-up-circle" style="font-size:28px;color:#ef4444;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Net Bakiye -->
    <div class="col-md-4 mb-3">
        <div class="card"
             style="border-radius:14px; box-shadow:0 2px 8px rgba(0,0,0,0.08);
                    border-left:4px solid #1AAFA3;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1" style="font-size:13px;">Net Bakiye</p>
                        <h3 class="fw-bold mb-0"
                            style="color:@(Model.TotalBalance >= 0 ? "#1AAFA3" : "#ef4444");">
                            @(Model.TotalBalance >= 0 ? "+" : "")₺@Model.TotalBalance.ToString("N2", culture)
                        </h3>
                        <small style="color:#9ca3af;font-size:11px;">Gelir − Gider</small>
                    </div>
                    <div style="width:56px;height:56px;background:#f0fdf4;border-radius:14px;
                                display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-wallet2" style="font-size:28px;color:#1AAFA3;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Gelir-Gider Oranı -->
@if (Model.TotalIncome > 0)
{
    var spendingRatio = (double)(Model.TotalExpense / Model.TotalIncome * 100);
    var ratioColor = spendingRatio <= 50 ? "#10b981" :
                     spendingRatio <= 75 ? "#f59e0b" :
                     spendingRatio <= 90 ? "#f97316" : "#ef4444";
    var ratioMessage = spendingRatio <= 50 ? "Harika! Gelirinizin büyük kısmını biriktiriyorsunuz 🎉" :
                       spendingRatio <= 75 ? "İyi gidiyorsunuz! Harcamalarınız kontrol altında 👍" :
                       spendingRatio <= 90 ? "Dikkat! Harcamalarınız yüksek ⚠️" :
                       "Uyarı! Gelirinizin çoğunu harcıyorsunuz 🚨";

    <div class="card mb-4" style="border-radius:14px; box-shadow:0 2px 8px rgba(0,0,0,0.08);">
        <div class="card-body">
            <h5 class="card-title mb-3">📈 Harcama Oranı</h5>
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fw-bold" style="font-size:14px;">Gelirinizin %@spendingRatio.ToString("N1")'ini harcadınız</span>
                <span class="badge" style="background:@ratioColor;color:white;font-size:11px;padding:5px 10px;border-radius:20px;">@ratioMessage</span>
            </div>
            <div class="progress" style="height:20px;border-radius:10px;background:#f3f4f6;">
                <div class="progress-bar" role="progressbar"
                     style="width:@(Math.Min(spendingRatio, 100))%;background:linear-gradient(90deg,@ratioColor,@ratioColor);border-radius:10px;"
                     aria-valuenow="@spendingRatio" aria-valuemin="0" aria-valuemax="100">
                </div>
            </div>
            <div class="d-flex justify-content-between mt-2">
                <small class="text-muted"><i class="bi bi-arrow-down-circle text-success me-1"></i>Gelir: ₺@Model.TotalIncome.ToString("N2", culture)</small>
                <small class="text-muted"><i class="bi bi-arrow-up-circle text-danger me-1"></i>Gider: ₺@Model.TotalExpense.ToString("N2", culture)</small>
            </div>
        </div>
    </div>
}

<!-- Birikim Hedefleri -->
@if (Model.RecentSavings != null && Model.RecentSavings.Any())
{
    <div class="card mb-4" style="border-radius:14px; box-shadow:0 2px 8px rgba(0,0,0,0.08);">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title mb-0">🎯 Birikim Hedefleri</h5>
                <a href="/Saving/Index" class="btn btn-sm btn-outline-primary" style="border-radius:8px;">Tümünü Gör</a>
            </div>
            <div class="row g-3">
                @foreach (var saving in Model.RecentSavings)
                {
                    var progressColor = saving.Progress >= 100 ? "#10b981" :
                    saving.Progress >= 75 ? "#1AAFA3" :
                    saving.Progress >= 50 ? "#f59e0b" : "#f97316";
                    <div class="col-md-4">
                        <div class="card h-100" style="border-radius:12px; border-left:4px solid @(saving.Color ?? "#1AAFA3");">
                            <div class="card-body p-3">
                                <h6 class="fw-bold mb-2">@(saving.Icon ?? "💰") @saving.GoalName</h6>
                                <div class="d-flex justify-content-between mb-1">
                                    <small class="fw-bold" style="color:@progressColor;">₺@saving.CurrentAmount.ToString("N2", culture)</small>
                                    <small class="text-muted">₺@saving.TargetAmount.ToString("N2", culture)</small>
                                </div>
                                <div class="progress" style="height:8px;border-radius:4px;background:#f3f4f6;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width:@(Math.Min(saving.Progress, 100))%;background:@progressColor;border-radius:4px;"
                                         aria-valuenow="@saving.Progress" aria-valuemin="0" aria-valuemax="100">
                                    </div>
                                </div>
                                <small class="text-muted" style="font-size:11px;">%@saving.Progress.ToString("N1") tamamlandı</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Son İşlemler -->
@if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
{
    <div class="card" style="border-radius:14px; box-shadow:0 2px 8px rgba(0,0,0,0.08);">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title mb-0">📋 Son İşlemler</h5>
                <a href="/Transaction/Index" class="btn btn-sm btn-outline-primary" style="border-radius:8px;">Tümünü Gör</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover" style="font-size:13px;">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>Kategori</th>
                            <th>Açıklama</th>
                            <th class="text-end">Tutar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var transaction in Model.RecentTransactions.Take(5))
                        {
                            <tr>
                                <td style="color:#9ca3af;">@transaction.Date.ToString("dd.MM.yyyy")</td>
                                <td>@transaction.CategoryIcon @transaction.CategoryName</td>
                                <td>@(transaction.Description ?? "-")</td>
                                <td class="text-end fw-bold">
                                    @if (transaction.Type == "Income")
                                    {
                                        <span style="color:#10b981;">+₺@transaction.Amount.ToString("N2", culture)</span>
                                    }
                                    else
                                    {
                                        <span style="color:#ef4444;">-₺@transaction.Amount.ToString("N2", culture)</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card" style="border-radius:14px;text-align:center;padding:60px;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
        <div style="font-size:48px;margin-bottom:12px;">📋</div>
        <h5 style="font-weight:600;color:#374151;">Henüz işlem yok</h5>
        <p class="text-muted">Sağ alttaki + butonunu kullanarak ilk işlemini ekle!</p>
    </div>
}