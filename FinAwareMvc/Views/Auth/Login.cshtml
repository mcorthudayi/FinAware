@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap — FinAware</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            min-height: 100vh;
            display: flex;
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: #f0fafa;
        }

        /* Sol panel */
        .brand-panel {
            width: 48%;
            background: linear-gradient(145deg, #1AAFA3 0%, #0D7A71 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px;
            position: relative;
            overflow: hidden;
        }

            .brand-panel::before {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                border-radius: 50%;
                background: rgba(255,255,255,0.05);
                top: -100px;
                right: -100px;
            }

            .brand-panel::after {
                content: '';
                position: absolute;
                width: 300px;
                height: 300px;
                border-radius: 50%;
                background: rgba(255,255,255,0.04);
                bottom: -80px;
                left: -80px;
            }

        .brand-logo {
            width: 140px;
            height: 140px;
            margin-bottom: 28px;
            position: relative;
            z-index: 1;
        }

        .brand-title {
            font-size: 38px;
            font-weight: 700;
            color: white;
            letter-spacing: -1px;
            position: relative;
            z-index: 1;
        }

        .brand-subtitle {
            font-size: 14px;
            color: rgba(255,255,255,0.7);
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-top: 6px;
            position: relative;
            z-index: 1;
        }

        .brand-features {
            margin-top: 48px;
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 320px;
        }

        .brand-feature {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            background: rgba(255,255,255,0.1);
            border-radius: 14px;
            margin-bottom: 12px;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,0.15);
        }

        .brand-feature-icon {
            width: 38px;
            height: 38px;
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .brand-feature-text {
            color: white;
            font-size: 14px;
            font-weight: 500;
        }

        .brand-feature-sub {
            color: rgba(255,255,255,0.6);
            font-size: 12px;
        }

        /* Sağ panel */
        .form-panel {
            width: 52%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px;
            background: white;
        }

        .form-box {
            width: 100%;
            max-width: 420px;
        }

        .form-title {
            font-size: 26px;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 6px;
        }

        .form-desc {
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 32px;
        }

        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        .input-wrapper {
            position: relative;
            margin-bottom: 18px;
        }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 16px;
        }

        .form-control {
            border: 1.5px solid #e5e7eb;
            border-radius: 12px;
            padding: 13px 14px 13px 42px;
            font-size: 14px;
            color: #1f2937;
            background: #f9fafb;
            transition: all 0.2s;
            width: 100%;
        }

            .form-control:focus {
                outline: none;
                border-color: #1AAFA3;
                background: white;
                box-shadow: 0 0 0 4px rgba(26, 175, 163, 0.1);
            }

            .form-control::placeholder {
                color: #9ca3af;
            }

        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #1AAFA3 0%, #0D7A71 100%);
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 8px;
            letter-spacing: 0.3px;
        }

            .btn-login:hover {
                transform: translateY(-1px);
                box-shadow: 0 8px 24px rgba(26, 175, 163, 0.35);
            }

            .btn-login:active {
                transform: translateY(0);
            }

        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 24px 0;
            color: #9ca3af;
            font-size: 13px;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: #e5e7eb;
            }

        .register-link {
            text-align: center;
            color: #6b7280;
            font-size: 14px;
        }

            .register-link a {
                color: #1AAFA3;
                font-weight: 600;
                text-decoration: none;
            }

                .register-link a:hover {
                    text-decoration: underline;
                }

        .alert {
            border-radius: 12px;
            font-size: 14px;
            border: none;
            padding: 12px 16px;
            margin-bottom: 16px;
        }

        .alert-success {
            background: #ecfdf5;
            color: #065f46;
        }

        .alert-danger {
            background: #fef2f2;
            color: #991b1b;
        }

        .alert-warning {
            background: #fffbeb;
            color: #92400e;
        }

        /* Mobil */
        @@media (max-width: 768px) {
            body

        {
            flex-direction: column;
        }

        .brand-panel {
            width: 100%;
            padding: 36px 24px;
            min-height: auto;
        }

        .brand-features {
            display: none;
        }

        .form-panel {
            width: 100%;
            padding: 32px 24px;
        }

        }
    </style>
</head>
<body>

    <!-- Sol: Marka Paneli -->
    <div class="brand-panel">
        <!-- SVG Logo -->
        <svg class="brand-logo" viewBox="0 0 680 680" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <clipPath id="lc"><circle cx="340" cy="340" r="280" /></clipPath>
                <linearGradient id="lg" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:rgba(255,255,255,0.25)" />
                    <stop offset="100%" style="stop-color:rgba(255,255,255,0.08)" />
                </linearGradient>
            </defs>
            <circle cx="340" cy="340" r="280" fill="rgba(255,255,255,0.12)" />
            <circle cx="340" cy="340" r="280" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2" />
            <circle cx="340" cy="340" r="240" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1" />
            <rect x="210" y="195" width="260" height="200" rx="20" fill="url(#lg)" stroke="rgba(255,255,255,0.25)" stroke-width="1.5" />
            <rect x="240" y="310" width="32" height="62" rx="6" fill="rgba(255,255,255,0.25)" />
            <rect x="286" y="275" width="32" height="97" rx="6" fill="rgba(255,255,255,0.55)" />
            <rect x="332" y="290" width="32" height="82" rx="6" fill="rgba(255,255,255,0.35)" />
            <rect x="378" y="248" width="32" height="124" rx="6" fill="white" />
            <polyline points="256,318 302,280 348,295 394,252" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="256" cy="318" r="4" fill="white" opacity="0.7" />
            <circle cx="302" cy="280" r="4" fill="white" opacity="0.7" />
            <circle cx="348" cy="295" r="4" fill="white" opacity="0.7" />
            <circle cx="394" cy="252" r="5" fill="white" />
            <rect x="222" y="207" width="90" height="22" rx="11" fill="rgba(255,255,255,0.15)" />
            <text x="267" y="222" text-anchor="middle" font-family="system-ui" font-size="11" font-weight="600" fill="rgba(255,255,255,0.9)" letter-spacing="0.5">BÜTÇE TAKİP</text>
        </svg>

        <div class="brand-title">FinAware</div>
        <div class="brand-subtitle">Finansal Asistan</div>

        <div class="brand-features">
            <div class="brand-feature">
                <div class="brand-feature-icon">💸</div>
                <div>
                    <div class="brand-feature-text">Gelir & Gider Takibi</div>
                    <div class="brand-feature-sub">Multi-currency, fatura OCR</div>
                </div>
            </div>
            <div class="brand-feature">
                <div class="brand-feature-icon">🎯</div>
                <div>
                    <div class="brand-feature-text">Bütçe & Birikim Hedefleri</div>
                    <div class="brand-feature-sub">Akıllı uyarılar, altın takibi</div>
                </div>
            </div>
            <div class="brand-feature">
                <div class="brand-feature-icon">🤖</div>
                <div>
                    <div class="brand-feature-text">Telegram AI Asistan</div>
                    <div class="brand-feature-sub">Sohbet ederek finansını yönet</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sağ: Form Paneli -->
    <div class="form-panel">
        <div class="form-box">
            <div class="form-title">Tekrar hoş geldin 👋</div>
            <div class="form-desc">Hesabına giriş yap ve finansını yönet.</div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                </div>
            }
            @if (ViewBag.SuccessMessage != null)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-2"></i>@ViewBag.SuccessMessage
                </div>
            }
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.ErrorMessage
                </div>
            }
            @if (ViewBag.ShowResendButton == true)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-envelope-exclamation me-2"></i>
                    <strong>E-posta doğrulanmamış!</strong><br>
                    <small>Gelen kutunuzu kontrol edin.</small>
                </div>
                <form method="post" action="/Auth/ResendVerification" class="mb-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="email" value="@ViewBag.UnverifiedEmail" />
                    <button type="submit" class="btn btn-outline-secondary btn-sm w-100" style="border-radius: 10px;">
                        <i class="bi bi-envelope me-2"></i>Doğrulama Mailini Tekrar Gönder
                    </button>
                </form>
            }

            <form method="post" action="/Auth/Login">
                @Html.AntiForgeryToken()

                <label class="form-label">E-posta</label>
                <div class="input-wrapper">
                    <i class="bi bi-envelope input-icon"></i>
                    <input type="email" class="form-control" name="email" required
                           placeholder="ornek@email.com" autocomplete="email" />
                </div>

                <label class="form-label">Şifre</label>
                <div class="input-wrapper">
                    <i class="bi bi-lock input-icon"></i>
                    <input type="password" class="form-control" name="password" required
                           placeholder="••••••••" autocomplete="current-password" id="passwordInput" />
                    <i class="bi bi-eye input-icon" style="left:auto; right:14px; cursor:pointer;"
                       id="togglePassword"></i>
                </div>

                <button type="submit" class="btn-login">
                    Giriş Yap
                </button>
            </form>

            <div class="divider">veya</div>

            <div class="register-link">
                Hesabın yok mu? <a href="/Auth/Register">Kayıt ol</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('togglePassword')?.addEventListener('click', function () {
            const input = document.getElementById('passwordInput');
            if (input.type === 'password') {
                input.type = 'text';
                this.className = this.className.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                this.className = this.className.replace('bi-eye-slash', 'bi-eye');
            }
        });
    </script>
</body>
</html>