@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kayıt Ol — FinAware</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            display: flex;
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: #f0fafa;
        }
        /*sol panel*/
        .brand-panel {
            width: 48%;
            background: linear-gradient(145deg, #1AAFA3 0%, #0D7A71 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 48px;
            position: relative;
            overflow: hidden;
        }

        .brand-panel::before {
            content: '';
            position: absolute;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            top: -100px; right: -100px;
        }

        .brand-panel::after {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
            bottom: -80px; left: -80px;
        }

        .brand-logo {
            width: 140px; height: 140px;
            margin-bottom: 28px;
            position: relative; z-index: 1;
        }

        .brand-title {
            font-size: 38px; font-weight: 700;
            color: white; letter-spacing: -1px;
            position: relative; z-index: 1;
        }

        .brand-subtitle {
            font-size: 14px;
            color: rgba(255,255,255,0.7);
            letter-spacing: 3px;
            text-transform: uppercase;
            margin-top: 6px;
            position: relative; z-index: 1;
        }

        .brand-steps {
            margin-top: 48px;
            position: relative; z-index: 1;
            width: 100%; max-width: 320px;
        }

        .brand-step {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 18px;
            background: rgba(255,255,255,0.1);
            border-radius: 14px;
            margin-bottom: 12px;
            border: 1px solid rgba(255,255,255,0.15);
        }

        .brand-step-num {
            width: 32px; height: 32px;
            background: rgba(255,255,255,0.2);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 15px; font-weight: 700;
            color: white; flex-shrink: 0;
        }

        .brand-step-text { color: white; font-size: 14px; font-weight: 500; }
        .brand-step-sub { color: rgba(255,255,255,0.6); font-size: 12px; }

        /* Form paneli */
        .form-panel {
            width: 52%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px;
            background: white;
            overflow-y: auto;
        }

        .form-box {
            width: 100%;
            max-width: 420px;
        }

        .form-title {
            font-size: 26px; font-weight: 700;
            color: #1a1a2e; margin-bottom: 6px;
        }

        .form-desc {
            color: #6b7280; font-size: 14px;
            margin-bottom: 28px;
        }

        .form-label {
            font-size: 13px; font-weight: 600;
            color: #374151; margin-bottom: 6px;
            display: block;
        }

        .input-wrapper {
            position: relative;
            margin-bottom: 16px;
        }

        .input-icon {
            position: absolute;
            left: 14px; top: 50%;
            transform: translateY(-50%);
            color: #9ca3af; font-size: 16px;
            pointer-events: none;
        }

        .input-icon-right {
            position: absolute;
            right: 14px; top: 50%;
            transform: translateY(-50%);
            color: #9ca3af; font-size: 16px;
            cursor: pointer;
        }

        .form-control {
            border: 1.5px solid #e5e7eb;
            border-radius: 12px;
            padding: 13px 14px 13px 42px;
            font-size: 14px; color: #1f2937;
            background: #f9fafb;
            transition: all 0.2s;
            width: 100%;
        }

        .form-control:focus {
            outline: none;
            border-color: #1AAFA3;
            background: white;
            box-shadow: 0 0 0 4px rgba(26, 175, 163, 0.1);
        }

        .form-control::placeholder { color: #9ca3af; }

        /* Şifre gücü göstergesi */
        .strength-bar {
            height: 4px;
            border-radius: 2px;
            background: #e5e7eb;
            margin-top: 6px;
            overflow: hidden;
        }

        .strength-fill {
            height: 100%;
            border-radius: 2px;
            width: 0%;
            transition: all 0.3s;
        }

        .strength-text {
            font-size: 11px;
            margin-top: 3px;
            color: #9ca3af;
        }

        /* Şifre eşleşme göstergesi */
        .match-indicator {
            font-size: 11px;
            margin-top: 3px;
            display: none;
        }

        .btn-register {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #1AAFA3 0%, #0D7A71 100%);
            border: none; border-radius: 12px;
            color: white; font-size: 15px;
            font-weight: 600; cursor: pointer;
            transition: all 0.2s;
            margin-top: 8px;
            letter-spacing: 0.3px;
        }

        .btn-register:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 24px rgba(26, 175, 163, 0.35);
        }

        .btn-register:active { transform: translateY(0); }

        .btn-register:disabled {
            opacity: 0.6; cursor: not-allowed;
            transform: none;
        }

        .divider {
            display: flex; align-items: center;
            gap: 12px; margin: 20px 0;
            color: #9ca3af; font-size: 13px;
        }

        .divider::before, .divider::after {
            content: ''; flex: 1;
            height: 1px; background: #e5e7eb;
        }

        .login-link {
            text-align: center;
            color: #6b7280; font-size: 14px;
        }

        .login-link a {
            color: #1AAFA3; font-weight: 600;
            text-decoration: none;
        }

        .login-link a:hover { text-decoration: underline; }

        .alert {
            border-radius: 12px; border: none;
            font-size: 14px; padding: 12px 16px;
            margin-bottom: 16px;
        }

        .alert-success { background: #ecfdf5; color: #065f46; }
        .alert-danger  { background: #fef2f2; color: #991b1b; }

        /* Kısa kurallar satırı */
        .rules-row {
            display: flex; gap: 12px;
            margin-top: 6px; flex-wrap: wrap;
        }

        .rule-chip {
            display: flex; align-items: center; gap: 4px;
            font-size: 11px; color: #9ca3af;
            transition: color 0.2s;
        }

        .rule-chip.valid { color: #059669; }
        .rule-chip i { font-size: 12px; }

        @@media (max-width: 768px) {
            body { flex-direction: column; }
            .brand-panel { width: 100%; padding: 36px 24px; min-height: auto; }
            .brand-steps { display: none; }
            .form-panel { width: 100%; padding: 32px 24px; }
        }
    </style>
</head>
<body>

    <!-- Sol: Marka Paneli -->
    <div class="brand-panel">
        <svg class="brand-logo" viewBox="0 0 680 680" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="lg" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:rgba(255,255,255,0.25)"/>
                    <stop offset="100%" style="stop-color:rgba(255,255,255,0.08)"/>
                </linearGradient>
            </defs>
            <circle cx="340" cy="340" r="280" fill="rgba(255,255,255,0.12)"/>
            <circle cx="340" cy="340" r="280" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
            <circle cx="340" cy="340" r="240" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
            <rect x="210" y="195" width="260" height="200" rx="20" fill="url(#lg)" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/>
            <rect x="240" y="310" width="32" height="62" rx="6" fill="rgba(255,255,255,0.25)"/>
            <rect x="286" y="275" width="32" height="97" rx="6" fill="rgba(255,255,255,0.55)"/>
            <rect x="332" y="290" width="32" height="82" rx="6" fill="rgba(255,255,255,0.35)"/>
            <rect x="378" y="248" width="32" height="124" rx="6" fill="white"/>
            <polyline points="256,318 302,280 348,295 394,252" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="256" cy="318" r="4" fill="white" opacity="0.7"/>
            <circle cx="302" cy="280" r="4" fill="white" opacity="0.7"/>
            <circle cx="348" cy="295" r="4" fill="white" opacity="0.7"/>
            <circle cx="394" cy="252" r="5" fill="white"/>
            <rect x="222" y="207" width="90" height="22" rx="11" fill="rgba(255,255,255,0.15)"/>
            <text x="267" y="222" text-anchor="middle" font-family="system-ui" font-size="11" font-weight="600" fill="rgba(255,255,255,0.9)" letter-spacing="0.5">BÜTÇE TAKİP</text>
        </svg>

        <div class="brand-title">FinAware</div>
        <div class="brand-subtitle">Finansal Asistan</div>

        <div class="brand-steps">
            <div class="brand-step">
                <div class="brand-step-num">1</div>
                <div>
                    <div class="brand-step-text">Hesap oluştur</div>
                    <div class="brand-step-sub">Ücretsiz, 30 saniyede</div>
                </div>
            </div>
            <div class="brand-step">
                <div class="brand-step-num">2</div>
                <div>
                    <div class="brand-step-text">E-postanı doğrula</div>
                    <div class="brand-step-sub">Gelen kutunu kontrol et</div>
                </div>
            </div>
            <div class="brand-step">
                <div class="brand-step-num">3</div>
                <div>
                    <div class="brand-step-text">Finansını yönet</div>
                    <div class="brand-step-sub">Harcama, bütçe, birikim</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sağ: Form Paneli -->
    <div class="form-panel">
        <div class="form-box">
            <div class="form-title">Hesap oluştur ✨</div>
            <div class="form-desc">Birkaç adımda finansal yolculuğuna başla.</div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                </div>
            }
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.ErrorMessage
                </div>
            }

            <form method="post" action="/Auth/Register" id="registerForm">
                @Html.AntiForgeryToken()

                <label class="form-label">Kullanıcı Adı</label>
                <div class="input-wrapper">
                    <i class="bi bi-person input-icon"></i>
                    <input type="text" class="form-control" name="username" id="usernameInput"
                           required placeholder="kullaniciadi" autocomplete="username"
                           minlength="3" maxlength="50" />
                </div>

                <label class="form-label">E-posta</label>
                <div class="input-wrapper">
                    <i class="bi bi-envelope input-icon"></i>
                    <input type="email" class="form-control" name="email" id="emailInput"
                           required placeholder="ornek@email.com" autocomplete="email" />
                </div>

                <label class="form-label">Şifre</label>
                <div class="input-wrapper">
                    <i class="bi bi-lock input-icon"></i>
                    <input type="password" class="form-control" name="password" id="passwordInput"
                           required placeholder="••••••••" autocomplete="new-password" minlength="6" />
                    <i class="bi bi-eye input-icon-right" id="togglePass1"></i>
                </div>
                <div class="strength-bar">
                    <div class="strength-fill" id="strengthFill"></div>
                </div>
                <div class="strength-text" id="strengthText"></div>
                <div class="rules-row" id="rulesRow">
                    <span class="rule-chip" id="ruleLen"><i class="bi bi-circle"></i> Min. 6 karakter</span>
                    <span class="rule-chip" id="ruleNum"><i class="bi bi-circle"></i> Rakam içermeli</span>
                    <span class="rule-chip" id="ruleCap"><i class="bi bi-circle"></i> Büyük harf</span>
                </div>

                <label class="form-label" style="margin-top: 14px;">Şifre Tekrar</label>
                <div class="input-wrapper">
                    <i class="bi bi-lock input-icon"></i>
                    <input type="password" class="form-control" name="confirmPassword" id="confirmInput"
                           required placeholder="••••••••" autocomplete="new-password" />
                    <i class="bi bi-eye input-icon-right" id="togglePass2"></i>
                </div>
                <div class="match-indicator" id="matchIndicator"></div>

                <button type="submit" class="btn-register" id="submitBtn">
                    Hesap Oluştur
                </button>
            </form>

            <div class="divider">veya</div>

            <div class="login-link">
                Zaten hesabın var mı? <a href="/Auth/Login">Giriş yap</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Şifre göster/gizle
        function togglePassword(inputId, iconEl) {
            const input = document.getElementById(inputId);
            if (input.type === 'password') {
                input.type = 'text';
                iconEl.className = iconEl.className.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                iconEl.className = iconEl.className.replace('bi-eye-slash', 'bi-eye');
            }
        }

        document.getElementById('togglePass1')?.addEventListener('click', function () {
            togglePassword('passwordInput', this);
        });
        document.getElementById('togglePass2')?.addEventListener('click', function () {
            togglePassword('confirmInput', this);
        });

        // Şifre gücü
        const passInput = document.getElementById('passwordInput');
        const strengthFill = document.getElementById('strengthFill');
        const strengthText = document.getElementById('strengthText');
        const ruleLen = document.getElementById('ruleLen');
        const ruleNum = document.getElementById('ruleNum');
        const ruleCap = document.getElementById('ruleCap');

        passInput?.addEventListener('input', function () {
            const val = this.value;
            let score = 0;

            const hasLen = val.length >= 6;
            const hasNum = /\d/.test(val);
            const hasCap = /[A-Z]/.test(val);
            const hasSpec = /[!#$%^&*]/.test(val);

            if (hasLen) score++;
            if (hasNum) score++;
            if (hasCap) score++;
            if (hasSpec) score++;

            // Kural chip'leri
            ruleLen.className = 'rule-chip' + (hasLen ? ' valid' : '');
            ruleLen.innerHTML = `<i class="bi bi-${hasLen ? 'check-circle-fill' : 'circle'}"></i> Min. 6 karakter`;
            ruleNum.className = 'rule-chip' + (hasNum ? ' valid' : '');
            ruleNum.innerHTML = `<i class="bi bi-${hasNum ? 'check-circle-fill' : 'circle'}"></i> Rakam içermeli`;
            ruleCap.className = 'rule-chip' + (hasCap ? ' valid' : '');
            ruleCap.innerHTML = `<i class="bi bi-${hasCap ? 'check-circle-fill' : 'circle'}"></i> Büyük harf`;

            const colors = ['', '#ef4444', '#f59e0b', '#3b82f6', '#10b981'];
            const labels = ['', 'Çok zayıf', 'Zayıf', 'İyi', 'Güçlü 💪'];
            strengthFill.style.width = `${score * 25}%`;
            strengthFill.style.background = colors[score] || '#e5e7eb';
            strengthText.textContent = val.length ? labels[score] : '';
            strengthText.style.color = colors[score];

            checkMatch();
        });

        // Şifre eşleşme
        const confirmInput = document.getElementById('confirmInput');
        const matchIndicator = document.getElementById('matchIndicator');

        function checkMatch() {
            const pass = passInput.value;
            const conf = confirmInput.value;
            if (!conf) { matchIndicator.style.display = 'none'; return; }
            matchIndicator.style.display = 'block';
            if (pass === conf) {
                matchIndicator.textContent = '✓ Şifreler eşleşiyor';
                matchIndicator.style.color = '#059669';
            } else {
                matchIndicator.textContent = '✗ Şifreler eşleşmiyor';
                matchIndicator.style.color = '#dc2626';
            }
        }

        confirmInput?.addEventListener('input', checkMatch);

        // Form submit
        document.getElementById('registerForm')?.addEventListener('submit', function (e) {
            const pass = passInput.value;
            const conf = confirmInput.value;

            if (pass !== conf) {
                e.preventDefault();
                matchIndicator.style.display = 'block';
                matchIndicator.textContent = '✗ Şifreler eşleşmiyor';
                matchIndicator.style.color = '#dc2626';
                confirmInput.focus();
                return;
            }

            if (pass.length < 6) {
                e.preventDefault();
                passInput.focus();
                return;
            }

            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.textContent = 'Hesap oluşturuluyor...';
        });
    </script>
</body>
</html>