@{
    ViewData["Title"] = "E-posta Doğrulama";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>E-posta Doğrulama - FinAware</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
</head>
<body style="background: linear-gradient(135deg, #E0F2F1 0%, #E3F2FD 100%); min-height: 100vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card" style="border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.1); border: none;">
                    <div class="card-body text-center p-5">

                        <div style="width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; background: @(ViewBag.Success == true ? "#E8F5E9" : "#FFEBEE");">
                            @if (ViewBag.Success == true)
                            {
                                <i class="bi bi-check-circle-fill" style="font-size: 40px; color: #4CAF50;"></i>
                            }
                            else
                            {
                                <i class="bi bi-x-circle-fill" style="font-size: 40px; color: #F44336;"></i>
                            }
                        </div>

                        <h2 class="fw-bold mb-3">
                            @(ViewBag.Success == true ? "E-posta Doğrulandı! 🎉" : "Doğrulama Başarısız")
                        </h2>

                        <p class="text-muted mb-4">@ViewBag.Message</p>

                        @if (ViewBag.Success == true)
                        {
                            <a href="/Auth/Login" class="btn btn-lg w-100"
                               style="background: linear-gradient(135deg, #4DB6AC 0%, #26A69A 100%); color: white; border-radius: 8px;">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
                            </a>
                        }
                        else
                        {
                            <a href="/Auth/Register" class="btn btn-lg w-100 btn-outline-primary">
                                <i class="bi bi-arrow-left me-2"></i>Tekrar Kayıt Ol
                            </a>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>