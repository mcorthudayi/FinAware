@using FinAware.MVC.Models.ViewModels
@model BudgetPageViewModel
@{
    ViewData["Title"] = "Bütçe Yönetimi";
    var monthNames = new[] { "", "Ocak", "Şubat", "Mart", "Nisan", "Mayıs", "Haziran", "Temmuz", "Ağustos", "Eylül", "Ekim", "Kasım", "Aralık" };
    var prevMonth = Model.Month == 1 ? 12 : Model.Month - 1;
    var prevYear = Model.Month == 1 ? Model.Year - 1 : Model.Year;
    var nextMonth = Model.Month == 12 ? 1 : Model.Month + 1;
    var nextYear = Model.Month == 12 ? Model.Year + 1 : Model.Year;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 fw-bold">💼 Bütçe Yönetimi</h1>
        <p class="text-muted">Aylık harcama limitlerini belirleyin</p>
    </div>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addBudgetModal">
        <i class="bi bi-plus-circle me-2"></i>Bütçe Ekle
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Ay Navigasyonu -->
<div class="card mb-4" style="border-radius: 12px;">
    <div class="card-body d-flex justify-content-between align-items-center">
        <a href="/Budget/Index?month=@prevMonth&year=@prevYear" class="btn btn-outline-secondary">
            <i class="bi bi-chevron-left"></i>
        </a>
        <h5 class="mb-0 fw-bold">@monthNames[Model.Month] @Model.Year</h5>
        <a href="/Budget/Index?month=@nextMonth&year=@nextYear" class="btn btn-outline-secondary">
            <i class="bi bi-chevron-right"></i>
        </a>
    </div>
</div>

<!-- Özet -->
<div class="card mb-4" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
    <div class="card-body">
        <h5 class="card-title mb-3">📊 Bu Ay Özeti</h5>
        <div class="row">
            <div class="col-md-4 text-center">
                <h3 class="fw-bold text-danger">₺@Model.TotalExpense.ToString("N2")</h3>
                <small class="text-muted">Toplam Harcama</small>
            </div>
            <div class="col-md-4 text-center">
                <h3 class="fw-bold" style="color: #4DB6AC;">@Model.Budgets.Count</h3>
                <small class="text-muted">Aktif Bütçe</small>
            </div>
            <div class="col-md-4 text-center">
                <h3 class="fw-bold text-warning">@Model.Budgets.Count(b => b.IsInfo || b.IsWarning || b.IsOver)</h3>
                <small class="text-muted">Bilgi / Uyarı / Aşım</small>
            </div>
        </div>
    </div>
</div>

<!-- Bütçe Listesi -->
@if (!Model.Budgets.Any())
{
    <div class="card" style="border-radius: 12px; text-align: center; padding: 60px;">
        <h3>💼 Henüz bütçe yok</h3>
        <p class="text-muted">Bu ay için bütçe limitlari belirleyin</p>
        <button type="button" class="btn btn-primary mt-3" data-bs-toggle="modal" data-bs-target="#addBudgetModal">
            <i class="bi bi-plus-circle me-2"></i>Bütçe Ekle
        </button>
    </div>
}
else
{
    <div class="row">
        @foreach (var budget in Model.Budgets)
        {
            var barColor = budget.IsOver ? "#F44336" : budget.IsWarning ? "#FF9800" : budget.IsInfo ? "#2196F3" : "#4CAF50";
            var cardBorder = budget.IsOver ? "#F44336" : budget.IsWarning ? "#FF9800" : budget.IsInfo ? "#2196F3" : "#4DB6AC";

            <div class="col-md-6 mb-4">
                <div class="card" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid @cardBorder;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="fw-bold mb-1">@budget.CategoryIcon @budget.CategoryName</h5>
                                <small class="text-muted">Limit: ₺@budget.LimitAmount.ToString("N2")</small>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                @if (budget.IsOver)
                                {
                                    <span class="badge bg-danger">🚨 Aşıldı</span>
                                }
                                else if (budget.IsWarning)
                                {
                                    <span class="badge bg-warning text-dark">⚠️ Uyarı</span>
                                }
                                else if (budget.IsInfo)
                                {
                                    <span class="badge bg-primary">📊 %50 Doldu</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">✅ Normal</span>
                                }
                                <form method="post" action="/Budget/Delete/@budget.BudgetId" style="display: inline;"
                                      onsubmit="return confirm('Bu bütçeyi silmek istediğinize emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="month" value="@Model.Month" />
                                    <input type="hidden" name="year" value="@Model.Year" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mb-1">
                            <small class="fw-bold" style="color: @barColor;">₺@budget.Spent.ToString("N2") harcandı</small>
                            <small class="text-muted">%@budget.Percentage.ToString("N1")</small>
                        </div>
                        <div class="progress mb-2" style="height: 12px; border-radius: 6px;">
                            <div class="progress-bar" role="progressbar"
                                 style="width: @(Math.Min(budget.Percentage, 100))%; background-color: @barColor;"
                                 aria-valuenow="@budget.Percentage" aria-valuemin="0" aria-valuemax="100">
                            </div>
                        </div>
                        <div class="d-flex justify-content-between">
                            <small class="text-muted">
                                @if (budget.IsOver)
                                {
                                    <span class="text-danger">₺@(Math.Abs(budget.Remaining).ToString("N2")) aşıldı</span>
                                }
                                else
                                {
                                    <span>₺@budget.Remaining.ToString("N2") kaldı</span>
                                }
                            </small>
                            <small class="text-muted">Limit: ₺@budget.LimitAmount.ToString("N2")</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Bütçe Ekle Modal -->
<div class="modal fade" id="addBudgetModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 15px;">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">💼 Bütçe Ekle</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form method="post" action="/Budget/Create">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="month" value="@Model.Month" />
                    <input type="hidden" name="year" value="@Model.Year" />

                    <div class="mb-3">
                        <label class="form-label">Kategori</label>
                        <select class="form-select" name="categoryId">
                            <option value="">💰 Genel Bütçe (Tüm Harcamalar)</option>
                            @foreach (var cat in Model.Categories.Where(c => c.Type == "Expense"))
                            {
                                <option value="@cat.CategoryId">@cat.Icon @cat.Name</option>
                            }
                        </select>
                        <small class="text-muted">Boş bırakırsanız toplam harcama limiti olarak ayarlanır</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Limit Tutarı (₺)</label>
                        <div class="input-group">
                            <span class="input-group-text">₺</span>
                            <input type="number" step="0.01" min="1" class="form-control" name="limitAmount" required placeholder="0.00">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Dönem</label>
                        <div class="row">
                            <div class="col-6">
                                <select class="form-select" name="month">
                                    @for (int m = 1; m <= 12; m++)
                                    {
                                        <option value="@m" selected="@(m == Model.Month)">@monthNames[m]</option>
                                    }
                                </select>
                            </div>
                            <div class="col-6">
                                <input type="number" class="form-control" name="year" value="@Model.Year" min="2020" max="2030">
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-circle me-2"></i>Bütçe Oluştur
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>