@using FinAware.MVC.Models.ViewModels
@model List<CategoryViewModel>
@{
    ViewData["Title"] = "Kategoriler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 fw-bold">Kategoriler</h1>
        <p class="text-muted">İşlemlerinizi organize edin</p>
    </div>
    <a href="/Category/Create" class="btn btn-lg" style="background: #4DB6AC; color: white;">
        <i class="bi bi-plus-lg me-2"></i>Kategori Ekle
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model != null && Model.Any())
{
    <div class="row g-3">
        @foreach (var category in Model)
        {
            <div class="col-md-3">
                <div class="card h-100" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                    <div class="card-body text-center p-4">
                        <div class="display-3 mb-3">@category.Icon</div>
                        <h5 class="card-title fw-bold">@category.Name</h5>
                        <span class="badge @(category.Type == "Income" ? "bg-success" : "bg-danger") mb-3">
                            @(category.Type == "Income" ? "Gelir" : "Gider")
                        </span>

                        <form action="/Category/Delete/@category.CategoryId" method="post" class="mt-3">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                <i class="bi bi-trash me-1"></i>Sil
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card" style="border-radius: 12px;">
        <div class="card-body text-center py-5">
            <i class="bi bi-tags display-1 text-muted"></i>
            <h4 class="mt-3">Henüz Kategori Yok</h4>
            <p class="text-muted">İlk kategorinizi oluşturun</p>
            <a href="/Category/Create" class="btn btn-lg mt-3" style="background: #4DB6AC; color: white;">
                <i class="bi bi-plus-lg me-2"></i>Kategori Ekle
            </a>
        </div>
    </div>
}