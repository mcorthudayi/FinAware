@using FinAware.MVC.Models.ViewModels
@using FinAware.MVC.Models
@model DashboardViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="mb-4">
    <h1 class="display-6 fw-bold">Merhaba, @(Context.Session.GetString("Username") ?? "Kullanıcı")! 👋</h1>
    <p class="text-muted">Bugün @DateTime.Now.ToString("dd MMMM yyyy, dddd", new System.Globalization.CultureInfo("tr-TR"))</p>
</div>

<!-- Özet Kartlar -->
<div class="row mb-4">
    <!-- Toplam Gelir -->
    <div class="col-md-4 mb-3">
        <div class="card" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid #4CAF50;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">💰 Toplam Gelir</p>
                        <h3 class="fw-bold mb-0" style="color: #4CAF50;">₺@Model.TotalIncome.ToString("N2")</h3>
                    </div>
                    <div style="width: 60px; height: 60px; background: #E8F5E9; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-arrow-down-circle" style="font-size: 30px; color: #4CAF50;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toplam Gider -->
    <div class="col-md-4 mb-3">
        <div class="card" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid #F44336;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">💸 Toplam Gider</p>
                        <h3 class="fw-bold mb-0" style="color: #F44336;">₺@Model.TotalExpense.ToString("N2")</h3>
                    </div>
                    <div style="width: 60px; height: 60px; background: #FFEBEE; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-arrow-up-circle" style="font-size: 30px; color: #F44336;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Net Bakiye -->
    <div class="col-md-4 mb-3">
        <div class="card" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 4px solid #4DB6AC;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">📊 Net Bakiye</p>
                        <h3 class="fw-bold mb-0" style="color: #4DB6AC;">₺@Model.TotalBalance.ToString("N2")</h3>
                    </div>
                    <div style="width: 60px; height: 60px; background: #E0F2F1; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-wallet2" style="font-size: 30px; color: #4DB6AC;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Gelir-Gider Oranı -->
@if (Model.TotalIncome > 0)
{
    var spendingRatio = (double)(Model.TotalExpense / Model.TotalIncome * 100);
    var ratioColor = spendingRatio <= 50 ? "#4CAF50" :
                     spendingRatio <= 75 ? "#FFC107" :
                     spendingRatio <= 90 ? "#FF9800" : "#F44336";
    var ratioMessage = spendingRatio <= 50 ? "Harika! Gelirinizin büyük kısmını biriktiriyorsunuz 🎉" :
                       spendingRatio <= 75 ? "İyi gidiyorsunuz! Harcamalarınız kontrol altında 👍" :
                       spendingRatio <= 90 ? "Dikkat! Harcamalarınız yüksek ⚠️" :
                       "Uyarı! Gelirinizin çoğunu harcıyorsunuz 🚨";

    <div class="card mb-4" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <div class="card-body">
            <h5 class="card-title mb-3">📈 Harcama Oranı</h5>
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="fw-bold">Gelirinizin %@spendingRatio.ToString("N1")'ini harcadınız</span>
                <span class="badge" style="background-color: @ratioColor; color: white;">@ratioMessage</span>
            </div>
            <div class="progress" style="height: 25px; border-radius: 12px; background: #f0f0f0;">
                <div class="progress-bar position-relative" role="progressbar"
                     style="width: @(Math.Min(spendingRatio, 100))%; background: linear-gradient(90deg, @ratioColor 0%, @ratioColor 100%); transition: width 0.6s ease;"
                     aria-valuenow="@spendingRatio" aria-valuemin="0" aria-valuemax="100">
                    <span class="position-absolute w-100 text-center fw-bold" style="color: white;">%@spendingRatio.ToString("N1")</span>
                </div>
            </div>
            <div class="d-flex justify-content-between mt-2">
                <small class="text-muted">
                    <i class="bi bi-arrow-down-circle text-success"></i> Gelir: ₺@Model.TotalIncome.ToString("N2")
                </small>
                <small class="text-muted">
                    <i class="bi bi-arrow-up-circle text-danger"></i> Gider: ₺@Model.TotalExpense.ToString("N2")
                </small>
            </div>
        </div>
    </div>
}

<!-- Birikim Hedefleri -->
@if (Model.RecentSavings != null && Model.RecentSavings.Any())
{
    <div class="card mb-4" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title mb-0">🎯 Birikim Hedefleri</h5>
                <a href="/Saving/Index" class="btn btn-sm btn-outline-primary">Tümünü Gör</a>
            </div>
            <div class="row g-3">
                @foreach (var saving in Model.RecentSavings)
                {
                    var progressColor = saving.Progress >= 100 ? "#4CAF50" :
                    saving.Progress >= 75 ? "#4DB6AC" :
                    saving.Progress >= 50 ? "#FFC107" : "#FF9800";
                    <div class="col-md-4">
                        <div class="card h-100" style="border-radius: 10px; border-left: 4px solid @(saving.Color ?? "#4DB6AC");">
                            <div class="card-body p-3">
                                <h6 class="fw-bold mb-1">@(saving.Icon ?? "💰") @saving.GoalName</h6>
                                <div class="d-flex justify-content-between mb-1">
                                    <small class="fw-bold" style="color: @progressColor;">₺@saving.CurrentAmount.ToString("N2")</small>
                                    <small class="text-muted">₺@saving.TargetAmount.ToString("N2")</small>
                                </div>
                                <div class="progress" style="height: 8px; border-radius: 4px;">
                                    <div class="progress-bar" role="progressbar"
                                         style="width: @(Math.Min(saving.Progress, 100))%; background-color: @progressColor;"
                                         aria-valuenow="@saving.Progress" aria-valuemin="0" aria-valuemax="100">
                                    </div>
                                </div>
                                <small class="text-muted">%@saving.Progress.ToString("N1") tamamlandı</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Son İşlemler -->
@if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
{
    <div class="card" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title mb-0">📋 Son İşlemler</h5>
                <a href="/Transaction/Index" class="btn btn-sm btn-outline-primary">Tümünü Gör</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>Kategori</th>
                            <th>Açıklama</th>
                            <th class="text-end">Tutar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var transaction in Model.RecentTransactions.Take(5))
                        {
                            <tr>
                                <td>@transaction.Date.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (transaction.CategoryName != null)
                                    {
                                        <span>@transaction.CategoryIcon @transaction.CategoryName</span>
                                    }
                                </td>
                                <td>@(transaction.Description ?? "-")</td>
                                <td class="text-end">
                                    @if (transaction.Type == "Income")
                                    {
                                        <span class="text-success fw-bold">+₺@transaction.Amount.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-bold">-₺@transaction.Amount.ToString("N2")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card" style="border-radius: 12px; text-align: center; padding: 60px;">
        <h3>📋 Henüz işlem yok</h3>
        <p class="text-muted">Sağ alttaki + butonunu kullanarak ilk işleminizi ekleyin!</p>
    </div>
}