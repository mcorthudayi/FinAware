@using FinAware.MVC.Models.ViewModels
@using FinAware.MVC.Models
@model DashboardViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
    var now = DateTime.Now;
    var hour = now.Hour;
    var greeting = hour < 12 ? "Günaydın" : hour < 18 ? "İyi günler" : "İyi akşamlar";
    var username = Context.Session.GetString("Username") ?? "Kullanıcı";
    var spendingRatio = Model.TotalIncome > 0 ? (double)(Model.TotalExpense / Model.TotalIncome * 100) : 0;
    var ratioColor = spendingRatio <= 50 ? "#10B981" : spendingRatio <= 75 ? "#F59E0B" : spendingRatio <= 90 ? "#F97316" : "#EF4444";
    var ratioMessage = spendingRatio <= 50 ? "Harika gidiyorsun! 🎉" : spendingRatio <= 75 ? "İyi gidiyorsun! 👍" : spendingRatio <= 90 ? "Harcamalar yüksek ⚠️" : "Limit aşıldı! 🚨";
}

<style>
    /* ── BANNER ── */
    .dash-banner {
        background: linear-gradient(160deg, #0D7A71 0%, #1AAFA3 60%, #02C39A 100%);
        border-radius: 20px;
        padding: 28px 24px 24px;
        margin-bottom: 24px;
        position: relative;
        overflow: hidden;
    }
    .dash-banner::before {
        content: '';
        position: absolute;
        width: 200px; height: 200px;
        border-radius: 50%;
        background: rgba(255,255,255,0.05);
        top: -60px; right: -40px;
        pointer-events: none;
    }
    .dash-banner::after {
        content: '';
        position: absolute;
        width: 140px; height: 140px;
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
        bottom: -40px; left: -30px;
        pointer-events: none;
    }
    .dash-banner-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 6px;
        position: relative;
        z-index: 1;
    }
    .dash-greeting {
        font-size: 12px;
        color: rgba(255,255,255,0.65);
        font-weight: 600;
        letter-spacing: 0.3px;
        margin-bottom: 4px;
    }
    .dash-username {
        font-size: 26px;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.5px;
        line-height: 1;
    }
    .dash-period {
        font-size: 11px;
        color: rgba(255,255,255,0.55);
        font-weight: 600;
        letter-spacing: 0.8px;
        text-transform: uppercase;
        margin: 14px 0 12px;
        position: relative;
        z-index: 1;
    }
    /* ── METRİK KARTLAR ── */
    .metric-row {
        display: flex;
        gap: 10px;
        margin-bottom: 16px;
        position: relative;
        z-index: 1;
    }
    .metric-card {
        flex: 1;
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 14px;
        padding: 12px 10px;
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
        display: block;
    }
    .metric-card:hover {
        background: rgba(255,255,255,0.2);
        text-decoration: none;
    }
    .metric-label {
        font-size: 9px;
        color: rgba(255,255,255,0.6);
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        margin-bottom: 5px;
    }
    .metric-value {
        font-size: 15px;
        font-weight: 800;
        color: #fff;
        line-height: 1;
        margin-bottom: 4px;
    }
    .metric-value.expense { color: #FCA5A5; }
    .metric-value.positive { color: #6EE7B7; }
    .metric-sub {
        font-size: 10px;
        color: #6EE7B7;
        font-weight: 600;
    }
    .metric-sub.expense { color: #FCA5A5; }
    /* ── HARCAMA ORANI ── */
    .ratio-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
        position: relative;
        z-index: 1;
    }
    .ratio-label { font-size: 12px; color: rgba(255,255,255,0.7); font-weight: 600; }
    .ratio-pct { font-size: 13px; font-weight: 800; }
    .ratio-bar-bg {
        height: 8px;
        background: rgba(255,255,255,0.2);
        border-radius: 4px;
        overflow: hidden;
        position: relative;
        z-index: 1;
    }
    .ratio-bar-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.8s ease;
    }
    /* ── SECTION BAŞLIĞI ── */
    .section-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
    }
    .section-title {
        font-size: 16px;
        font-weight: 800;
        color: var(--text-primary);
        letter-spacing: -0.2px;
    }
    .section-link {
        font-size: 13px;
        color: var(--primary);
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.15s;
    }
    .section-link:hover { opacity: 0.75; text-decoration: none; }
    /* ── BİRİKİM KARTLARI ── */
    .saving-scroll {
        display: flex;
        gap: 14px;
        overflow-x: auto;
        padding-bottom: 8px;
        scrollbar-width: none;
        -ms-overflow-style: none;
        margin: 0 -4px;
        padding: 4px 4px 12px;
    }
    .saving-scroll::-webkit-scrollbar { display: none; }
    .saving-card {
        min-width: 220px;
        background: white;
        border-radius: 18px;
        border: 1.5px solid var(--border-color);
        padding: 16px;
        position: relative;
        overflow: hidden;
        flex-shrink: 0;
    }
    .saving-accent {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 4px;
        border-radius: 18px 0 0 18px;
    }
    .saving-inner { padding-left: 10px; }
    .saving-top {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
    }
    .saving-icon-box {
        width: 42px; height: 42px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }
    .saving-name { font-size: 14px; font-weight: 700; color: var(--text-primary); margin-bottom: 4px; }
    .saving-badge {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 11px; font-weight: 700;
        padding: 3px 8px; border-radius: 20px; border: 1px solid;
    }
    .saving-badge-dot { width: 6px; height: 6px; border-radius: 50%; }
    .saving-amounts {
        display: flex;
        align-items: center;
        border-radius: 10px;
        padding: 10px;
        border: 1px solid;
        margin-bottom: 10px;
    }
    .saving-amt-block { flex: 1; text-align: center; }
    .saving-amt-label { font-size: 10px; color: var(--text-secondary); font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 3px; }
    .saving-amt-value { font-size: 15px; font-weight: 800; }
    .saving-amt-divider { width: 1px; height: 28px; margin: 0 8px; }
    .saving-progress-bar {
        height: 6px; background: rgba(0,0,0,0.07); border-radius: 3px; overflow: hidden; margin-bottom: 6px;
    }
    .saving-progress-fill { height: 100%; border-radius: 3px; }
    .saving-remain { font-size: 11px; color: var(--text-secondary); }
    /* ── İŞLEM LİSTESİ ── */
    .tx-card {
        background: white;
        border-radius: 20px;
        border: 1.5px solid var(--border-color);
        overflow: hidden;
    }
    .tx-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-bottom: 1px solid #f3f4f6;
        transition: background 0.12s;
    }
    .tx-row:last-child { border-bottom: none; }
    .tx-row:hover { background: #fafafa; }
    .tx-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; flex-shrink: 0;
    }
    .tx-info { flex: 1; min-width: 0; }
    .tx-name { font-size: 14px; font-weight: 600; color: var(--text-primary); margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .tx-meta { font-size: 12px; color: var(--text-secondary); }
    .tx-amount { font-size: 15px; font-weight: 800; flex-shrink: 0; }
    .tx-amount.income { color: #10B981; }
    .tx-amount.expense { color: #EF4444; }
    /* ── BOŞ STATE ── */
    .empty-state {
        text-align: center;
        padding: 48px 24px;
        background: white;
        border-radius: 20px;
        border: 1.5px solid var(--border-color);
    }
    .empty-emoji { font-size: 48px; margin-bottom: 12px; }
    .empty-title { font-size: 17px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
    .empty-sub { font-size: 14px; color: var(--text-secondary); }
</style>

<!-- ── BANNER ── -->
<div class="dash-banner">
    <div class="dash-banner-header">
        <div>
            <div class="dash-greeting">@greeting 👋</div>
            <div class="dash-username">@username</div>
        </div>
        <a href="/Notification/Index" class="position-relative" style="text-decoration:none;">
            <div style="width:44px;height:44px;background:rgba(255,255,255,0.15);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:20px;">🔔</div>
        </a>
    </div>

    <div class="dash-period">
        📊 @now.ToString("MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")) · Finansal Özet
    </div>

    <!-- Metrik Kartlar -->
    <div class="metric-row">
        <a href="/Transaction/Index" class="metric-card">
            <div class="metric-label">💰 GELİR</div>
            <div class="metric-value">+₺@((Model.TotalIncome >= 1000 ? (Model.TotalIncome / 1000).ToString("N0") + "K" : Model.TotalIncome.ToString("N0")))</div>
            <div class="metric-sub">Gelir Ekle</div>
        </a>
        <a href="/Transaction/Index" class="metric-card">
            <div class="metric-label">💸 GİDER</div>
            <div class="metric-value expense">-₺@((Model.TotalExpense >= 1000 ? (Model.TotalExpense / 1000).ToString("N0") + "K" : Model.TotalExpense.ToString("N0")))</div>
            <div class="metric-sub expense">Gider Ekle</div>
        </a>
        <div class="metric-card" style="cursor:default;">
            <div class="metric-label">💼 NET</div>
            <div class="metric-value @(Model.TotalBalance >= 0 ? "positive" : "expense")">
                @(Model.TotalBalance >= 0 ? "+" : "")₺@((Math.Abs((double)Model.TotalBalance) >= 1000 ? (Math.Abs((double)Model.TotalBalance) / 1000).ToString("N0") + "K" : Math.Abs((double)Model.TotalBalance).ToString("N0")))
            </div>
            <div class="metric-sub">@(Model.RecentTransactions?.Count ?? 0) işlem</div>
        </div>
    </div>

    <!-- Harcama Oranı -->
    @if (Model.TotalIncome > 0)
    {
        <div class="ratio-header">
            <span class="ratio-label">Harcama Oranı</span>
            <span class="ratio-pct" style="color:@ratioColor;">%@spendingRatio.ToString("N1")</span>
        </div>
        <div class="ratio-bar-bg">
            <div class="ratio-bar-fill" style="width:@(Math.Min(spendingRatio,100))%;background:@ratioColor;"></div>
        </div>
    }
</div>

<!-- ── BİRİKİM HEDEFLERİ ── -->
@if (Model.RecentSavings != null && Model.RecentSavings.Any())
{
    <div class="mb-4">
        <div class="section-head">
            <div class="section-title">🎯 Birikim Hedefleri</div>
            <a href="/Saving/Index" class="section-link">Tümünü Gör →</a>
        </div>
        <div class="saving-scroll">
            @foreach (var s in Model.RecentSavings)
            {
                var pct = s.TargetAmount > 0 ? Math.Min((double)s.CurrentAmount / (double)s.TargetAmount * 100, 100) : 0;
                var pColor = pct >= 100 ? "#10B981" : pct >= 75 ? "#1AAFA3" : pct >= 50 ? "#F59E0B" : "#F97316";
                var remaining = s.TargetAmount - s.CurrentAmount;
                <div class="saving-card">
                    <div class="saving-accent" style="background:@pColor;"></div>
                    <div class="saving-inner">
                        <div class="saving-top">
                            <div class="saving-icon-box" style="background:@(pColor)18;">
                                <span>@(s.Icon ?? "💰")</span>
                            </div>
                            <div>
                                <div class="saving-name">@s.GoalName</div>
                                <div class="saving-badge" style="color:@pColor;background:@(pColor)15;border-color:@(pColor)40;">
                                    <div class="saving-badge-dot" style="background:@pColor;"></div>
                                    %@pct.ToString("N0")
                                </div>
                            </div>
                        </div>
                        <div class="saving-amounts" style="background:@(pColor)10;border-color:@(pColor)25;">
                            <div class="saving-amt-block">
                                <div class="saving-amt-label">Birikim</div>
                                <div class="saving-amt-value" style="color:@pColor;">₺@s.CurrentAmount.ToString("N0")</div>
                            </div>
                            <div class="saving-amt-divider" style="background:@(pColor)25;"></div>
                            <div class="saving-amt-block">
                                <div class="saving-amt-label">Hedef</div>
                                <div class="saving-amt-value" style="color:var(--text-primary);">₺@s.TargetAmount.ToString("N0")</div>
                            </div>
                        </div>
                        <div class="saving-progress-bar">
                            <div class="saving-progress-fill" style="width:@(pct)%;background:@pColor;"></div>
                        </div>
                        <div class="saving-remain">
                            @if (pct >= 100) { <span>🎉 Hedefe ulaştın!</span> }
                            else { <span>₺@remaining.ToString("N0") daha</span> }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- ── SON İŞLEMLER ── -->
<div class="mb-4">
    <div class="section-head">
        <div class="section-title">📋 Son İşlemler</div>
        <a href="/Transaction/Index" class="section-link">Tümünü Gör →</a>
    </div>

    @if (Model.RecentTransactions != null && Model.RecentTransactions.Any())
    {
        <div class="tx-card">
            @foreach (var tx in Model.RecentTransactions.Take(8))
            {
                <div class="tx-row">
                    <div class="tx-icon" style="background:@(tx.Type == "Income" ? "#ECFDF5" : "#FEF2F2");">
                        @(tx.CategoryIcon ?? "💳")
                    </div>
                    <div class="tx-info">
                        <div class="tx-name">@(tx.Description ?? tx.CategoryName ?? "-")</div>
                        <div class="tx-meta">@tx.CategoryName · @tx.Date.ToString("dd.MM.yyyy")</div>
                    </div>
                    <div class="tx-amount @(tx.Type == "Income" ? "income" : "expense")">
                        @(tx.Type == "Income" ? "+" : "-")₺@tx.Amount.ToString("N2")
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-emoji">📭</div>
            <div class="empty-title">Henüz işlem yok</div>
            <div class="empty-sub">Sağ alttaki + butonuyla ilk işlemini ekle</div>
        </div>
    }
</div>
