@using FinAware.MVC.Models.ViewModels
@model List<NotificationViewModel>
@{
    ViewData["Title"] = "Bildirimler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="display-6 fw-bold">Bildirimler</h1>
        <p class="text-muted">Tüm bildirimleriniz</p>
    </div>
    @if (Model.Any(n => !n.IsRead))
    {
        <form method="post" action="/Notification/MarkAllAsRead" style="display: inline;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary">
                <i class="bi bi-check-all me-1"></i>Tümünü Okundu İşaretle
            </button>
        </form>
    }
</div>

@if (Model != null && Model.Any())
{
    <div class="card" style="border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
        <div class="card-body p-0">
            @foreach (var notification in Model)
            {
                <div class="notification-item @(notification.IsRead ? "" : "unread")"
                     style="padding: 16px 24px; border-bottom: 1px solid #f0f0f0; display: flex; align-items: start; gap: 16px; @(notification.IsRead ? "" : "background: #f8f9fa;")">

                    <div style="font-size: 32px; flex-shrink: 0;">
                        @notification.Icon
                    </div>

                    <div style="flex: 1;">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="mb-0 fw-bold">@notification.Title</h6>
                            <small class="text-muted">@notification.TimeAgo</small>
                        </div>
                        <p class="mb-0 text-muted">@notification.Message</p>

                        @if (!notification.IsRead)
                        {
                            <span class="badge bg-primary mt-2">Yeni</span>
                        }
                    </div>

                    <div class="dropdown">
                        <button class="btn btn-sm btn-light" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu">
                            @if (!notification.IsRead)
                            {
                                <li>
                                    <form method="post" action="/Notification/MarkAsRead/@notification.NotificationId" style="margin: 0;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">
                                            <i class="bi bi-check me-2"></i>Okundu İşaretle
                                        </button>
                                    </form>
                                </li>
                            }
                            <li>
                                <form method="post" action="/Notification/Delete/@notification.NotificationId" style="margin: 0;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Bildirimi silmek istediğinize emin misiniz?')">
                                        <i class="bi bi-trash me-2"></i>Sil
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="card" style="border-radius: 12px;">
        <div class="card-body text-center py-5">
            <i class="bi bi-bell-slash display-1 text-muted"></i>
            <h4 class="mt-3">Henüz Bildirim Yok</h4>
            <p class="text-muted">Yeni bildirimleriniz burada görünecek</p>
        </div>
    </div>
}