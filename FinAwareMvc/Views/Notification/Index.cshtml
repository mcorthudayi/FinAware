@using FinAware.MVC.Models.ViewModels
@model List<NotificationViewModel>
@{
    ViewData["Title"] = "Bildirimler";
}

<style>
    .page-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; }
    .page-title { font-size:26px; font-weight:900; color:var(--text-primary); letter-spacing:-0.5px; }
    .page-sub { font-size:14px; color:var(--text-secondary); margin-top:4px; }
    .btn-mark-all { background:white; border:1.5px solid var(--border-color); color:var(--text-secondary); padding:10px 18px; border-radius:12px; font-size:13px; font-weight:600; cursor:pointer; display:flex; align-items:center; gap:7px; transition:all 0.15s; }
    .btn-mark-all:hover { border-color:var(--primary); color:var(--primary); }
    .notif-card { background:white; border-radius:20px; border:1.5px solid var(--border-color); overflow:hidden; }
    .notif-row { display:flex; align-items:flex-start; gap:14px; padding:16px 20px; border-bottom:1px solid #f3f4f6; transition:background 0.12s; position:relative; }
    .notif-row:last-child { border-bottom:none; }
    .notif-row.unread { background:#F8FDFC; }
    .notif-row:hover { background:#fafafa; }
    .notif-row.unread:hover { background:#F0FAF9; }
    .notif-icon { font-size:28px; flex-shrink:0; width:44px; text-align:center; margin-top:2px; }
    .notif-body { flex:1; min-width:0; }
    .notif-title-row { display:flex; justify-content:space-between; align-items:flex-start; gap:8px; margin-bottom:4px; }
    .notif-title { font-size:14px; font-weight:700; color:var(--text-primary); }
    .notif-time { font-size:12px; color:var(--text-secondary); flex-shrink:0; }
    .notif-msg { font-size:13px; color:var(--text-secondary); line-height:1.5; margin-bottom:4px; }
    .notif-new-badge { display:inline-block; font-size:10px; font-weight:700; background:#E8F7F6; color:var(--primary); padding:2px 8px; border-radius:20px; }
    .notif-unread-dot { position:absolute; top:50%; right:20px; transform:translateY(-50%); width:8px; height:8px; border-radius:50%; background:var(--primary); }
    .notif-actions { display:flex; flex-direction:column; gap:4px; flex-shrink:0; }
    .btn-notif { background:none; border:none; color:#d1d5db; cursor:pointer; padding:6px 8px; border-radius:8px; font-size:13px; transition:all 0.15s; white-space:nowrap; }
    .btn-notif:hover { color:var(--primary); background:#E8F7F6; }
    .btn-notif.danger:hover { color:#EF4444; background:#FEF2F2; }
    .empty-state { text-align:center; padding:64px 24px; background:white; border-radius:20px; border:1.5px solid var(--border-color); }
</style>

<div class="page-header">
    <div>
        <div class="page-title">🔔 Bildirimler</div>
        <div class="page-sub">Tüm bildirimleriniz</div>
    </div>
    @if (Model.Any(n => !n.IsRead))
    {
        <form method="post" action="/Notification/MarkAllAsRead">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-mark-all"><i class="bi bi-check-all"></i> Tümünü Okundu İşaretle</button>
        </form>
    }
</div>

@if (Model != null && Model.Any())
{
    <div class="notif-card">
        @foreach (var n in Model)
        {
            <div class="notif-row @(n.IsRead ? "" : "unread")">
                <div class="notif-icon">@n.Icon</div>
                <div class="notif-body">
                    <div class="notif-title-row">
                        <div class="notif-title">@n.Title</div>
                        <div class="notif-time">@n.TimeAgo</div>
                    </div>
                    <div class="notif-msg">@n.Message</div>
                    @if (!n.IsRead) { <span class="notif-new-badge">Yeni</span> }
                </div>
                <div class="notif-actions">
                    @if (!n.IsRead)
                    {
                        <form method="post" action="/Notification/MarkAsRead/@n.NotificationId" style="margin:0;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-notif"><i class="bi bi-check"></i></button>
                        </form>
                    }
                    <form method="post" action="/Notification/Delete/@n.NotificationId" style="margin:0;" onsubmit="return confirm('Bildirimi silmek istediğine emin misin?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-notif danger"><i class="bi bi-trash"></i></button>
                    </form>
                </div>
                @if (!n.IsRead) { <div class="notif-unread-dot"></div> }
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <div style="font-size:56px;margin-bottom:12px;opacity:0.4;">🔕</div>
        <div style="font-size:17px;font-weight:700;margin-bottom:6px;">Henüz Bildirim Yok</div>
        <div style="font-size:14px;color:var(--text-secondary);">Yeni bildirimler burada görünecek</div>
    </div>
}
