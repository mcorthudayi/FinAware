@using FinAware.MVC.Models
@model List<SavingViewModel>
@{
    ViewData["Title"] = "Birikimlerim";
}

<style>
    .page-header { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:24px; }
    .page-title { font-size:26px; font-weight:900; color:var(--text-primary); letter-spacing:-0.5px; }
    .page-sub { font-size:14px; color:var(--text-secondary); margin-top:4px; }
    .btn-add { background:var(--primary); color:white; border:none; padding:11px 20px; border-radius:12px; font-size:14px; font-weight:700; cursor:pointer; display:flex; align-items:center; gap:8px; transition:all 0.2s; text-decoration:none; }
    .btn-add:hover { background:var(--primary-dark); transform:translateY(-1px); color:white; }
    .saving-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:16px; }
    .saving-card { background:white; border-radius:18px; border:1.5px solid var(--border-color); padding:18px; position:relative; overflow:hidden; transition:all 0.2s; }
    .saving-card:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(0,0,0,0.06); }
    .saving-accent { position:absolute; left:0; top:0; bottom:0; width:4px; border-radius:18px 0 0 18px; }
    .saving-inner { padding-left:12px; }
    .saving-top { display:flex; align-items:center; gap:10px; margin-bottom:12px; }
    .saving-icon-box { width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0; }
    .saving-name { font-size:15px; font-weight:700; color:var(--text-primary); margin-bottom:3px; }
    .saving-date { font-size:12px; color:var(--text-secondary); }
    .saving-badge { display:inline-flex; align-items:center; gap:4px; font-size:11px; font-weight:700; padding:3px 8px; border-radius:20px; border:1px solid; }
    .saving-amounts { display:flex; align-items:center; border-radius:10px; padding:10px; border:1px solid; margin-bottom:10px; }
    .saving-amt-block { flex:1; text-align:center; }
    .saving-amt-label { font-size:10px; color:var(--text-secondary); font-weight:600; text-transform:uppercase; letter-spacing:0.4px; margin-bottom:2px; }
    .saving-amt-value { font-size:15px; font-weight:800; }
    .saving-amt-divider { width:1px; height:28px; margin:0 8px; }
    .saving-prog-bg { height:7px; background:#f3f4f6; border-radius:4px; overflow:hidden; margin-bottom:6px; }
    .saving-prog-fill { height:100%; border-radius:4px; }
    .saving-remain { font-size:11px; color:var(--text-secondary); margin-bottom:14px; }
    .saving-actions { display:flex; gap:6px; }
    .btn-action { flex:1; padding:8px; border-radius:10px; font-size:13px; font-weight:600; cursor:pointer; border:1.5px solid; transition:all 0.15s; display:flex; align-items:center; justify-content:center; gap:6px; text-decoration:none; }
    .btn-action.outline { background:white; color:var(--primary); border-color:var(--primary); }
    .btn-action.outline:hover { background:var(--primary); color:white; }
    .btn-action.danger { background:white; color:#EF4444; border-color:#EF4444; }
    .btn-action.danger:hover { background:#FEF2F2; }
    .add-form { border-top:1px solid #f3f4f6; padding-top:14px; margin-top:2px; }
    .form-row { display:flex; gap:6px; margin-bottom:8px; }
    .form-input { flex:1; padding:9px 12px; border-radius:10px; border:1.5px solid var(--border-color); font-size:13px; outline:none; transition:border-color 0.15s; }
    .form-input:focus { border-color:var(--primary); }
    .form-select-sm { padding:9px 10px; border-radius:10px; border:1.5px solid var(--border-color); font-size:13px; outline:none; background:white; }
    .btn-submit { width:100%; padding:10px; border-radius:10px; background:var(--primary); color:white; border:none; font-size:13px; font-weight:700; cursor:pointer; transition:background 0.15s; }
    .btn-submit:hover { background:var(--primary-dark); }
    .empty-state { text-align:center; padding:56px 24px; background:white; border-radius:20px; border:1.5px solid var(--border-color); }
</style>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="page-header">
    <div>
        <div class="page-title">💰 Birikimlerim</div>
        <div class="page-sub">Birikim hedeflerini takip et</div>
    </div>
    <a href="/Saving/Create" class="btn-add"><i class="bi bi-plus-lg"></i> Yeni Hedef</a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="empty-state">
        <div style="font-size:48px;margin-bottom:12px;">🎯</div>
        <div style="font-size:17px;font-weight:700;margin-bottom:6px;">Henüz birikim hedefin yok</div>
        <div style="font-size:14px;color:var(--text-secondary);margin-bottom:20px;">İlk hedefini oluştur ve biriktirmeye başla</div>
        <a href="/Saving/Create" class="btn-add" style="display:inline-flex;margin:0 auto;">
            <i class="bi bi-plus-lg"></i> Hedef Ekle
        </a>
    </div>
}
else
{
    <div class="saving-grid">
        @foreach (var s in Model)
        {
            var pct = s.TargetAmount > 0 ? Math.Min((double)s.CurrentAmount / (double)s.TargetAmount * 100, 100) : 0;
            var pColor = pct >= 100 ? "#10B981" : pct >= 75 ? "#1AAFA3" : pct >= 50 ? "#F59E0B" : "#F97316";
            var remaining = s.TargetAmount - s.CurrentAmount;
            <div class="saving-card">
                <div class="saving-accent" style="background:@pColor;"></div>
                <div class="saving-inner">
                    <div class="saving-top">
                        <div class="saving-icon-box" style="background:@(pColor)18;">@(s.Icon ?? "💰")</div>
                        <div style="flex:1;min-width:0;">
                            <div class="saving-name">@s.GoalName</div>
                            @if (s.TargetDate.HasValue)
                            {
                                <div class="saving-date">🗓️ @s.TargetDate.Value.ToString("dd.MM.yyyy")</div>
                            }
                        </div>
                        <span class="saving-badge" style="color:@pColor;background:@(pColor)15;border-color:@(pColor)40;">%@pct.ToString("N0")</span>
                    </div>
                    <div class="saving-amounts" style="background:@(pColor)10;border-color:@(pColor)25;">
                        <div class="saving-amt-block">
                            <div class="saving-amt-label">Birikim</div>
                            <div class="saving-amt-value" style="color:@pColor;">₺@s.CurrentAmount.ToString("N0")</div>
                        </div>
                        <div class="saving-amt-divider" style="background:@(pColor)25;"></div>
                        <div class="saving-amt-block">
                            <div class="saving-amt-label">Hedef</div>
                            <div class="saving-amt-value" style="color:var(--text-primary);">₺@s.TargetAmount.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="saving-prog-bg">
                        <div class="saving-prog-fill" style="width:@pct%;background:@pColor;"></div>
                    </div>
                    <div class="saving-remain">
                        @if (pct >= 100) { <span>🎉 Hedefe ulaştın!</span> }
                        else { <span>₺@remaining.ToString("N0") daha gerekiyor</span> }
                    </div>
                    <div class="saving-actions" style="margin-bottom:12px;">
                        <a href="/Saving/Details/@s.SavingId" class="btn-action outline"><i class="bi bi-bar-chart-line"></i> Detay</a>
                        <form method="post" action="/Saving/Delete/@s.SavingId" style="flex:1;" onsubmit="return confirm('Bu birikim hedefini silmek istediğine emin misin?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-action danger w-100"><i class="bi bi-trash"></i> Sil</button>
                        </form>
                    </div>
                    <!-- Tutar Ekleme -->
                    <div class="add-form">
                        <form method="post" action="/Saving/AddAmount/@s.SavingId">
                            @Html.AntiForgeryToken()
                            <div class="form-row">
                                <input type="number" step="0.0001" min="0.0001" name="amount" class="form-input" placeholder="Miktar" required id="amount-@s.SavingId">
                                <select name="currency" class="form-select-sm" id="currency-@s.SavingId" onchange="onCurrencyChange(@s.SavingId)" style="width:110px;flex-shrink:0;">
                                    <option value="TRY">₺ TRY</option>
                                    <option value="USD">$ USD</option>
                                    <option value="EUR">€ EUR</option>
                                    <option value="GBP">£ GBP</option>
                                    <option value="CHF">Fr CHF</option>
                                    <option value="XAU">🥇 Altın</option>
                                    <option value="XAG">🥈 Gümüş</option>
                                </select>
                            </div>
                            <div id="rate-box-@s.SavingId" style="display:none;margin-bottom:8px;">
                                <div id="auto-rate-@s.SavingId" style="display:none;"><small class="text-muted" id="auto-rate-text-@s.SavingId"></small></div>
                                <div id="manual-rate-@s.SavingId" style="display:none;">
                                    <div class="alert alert-warning py-2 px-3 mb-2" style="font-size:12px;">
                                        Altın/Gümüş için kur gir veya boş bırak (uluslararası kur kullanılır).<br>
                                        Tahmini: <strong id="auto-metal-rate-@s.SavingId"></strong>
                                    </div>
                                    <input type="number" step="0.01" min="1" class="form-input" name="manualRate" id="manual-rate-input-@s.SavingId" placeholder="₺/gram (opsiyonel)">
                                </div>
                            </div>
                            <input type="hidden" name="note" value="">
                            <button type="submit" class="btn-submit"><i class="bi bi-plus me-1"></i>Ekle</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
    let cachedRates = null;
    async function loadRates() {
        if (cachedRates) return cachedRates;
        try { const r = await fetch('/Saving/GetRates'); if (r.ok) cachedRates = await r.json(); } catch(e) {}
        return cachedRates;
    }
    async function onCurrencyChange(id) {
        const cur = document.getElementById(`currency-${id}`).value;
        const rateBox = document.getElementById(`rate-box-${id}`);
        const autoRate = document.getElementById(`auto-rate-${id}`);
        const manualRate = document.getElementById(`manual-rate-${id}`);
        const autoRateText = document.getElementById(`auto-rate-text-${id}`);
        const autoMetalRate = document.getElementById(`auto-metal-rate-${id}`);
        if (cur === 'TRY') { rateBox.style.display = 'none'; return; }
        rateBox.style.display = 'block';
        const rates = await loadRates();
        if (!rates) return;
        const d = rates.find(r => r.code === cur);
        if (cur === 'XAU' || cur === 'XAG') {
            autoRate.style.display = 'none'; manualRate.style.display = 'block';
            if (d) autoMetalRate.textContent = `~₺${d.rate.toFixed(2)}/gram`;
        } else {
            autoRate.style.display = 'block'; manualRate.style.display = 'none';
            if (d) { const n = {USD:'Dolar',EUR:'Euro',GBP:'Sterlin',CHF:'Frank'}; autoRateText.textContent = `Güncel kur: 1 ${n[cur]||cur} = ₺${d.rate.toFixed(4)} (TCMB)`; }
        }
    }
    document.addEventListener('DOMContentLoaded', loadRates);
</script>
}
