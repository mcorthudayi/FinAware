<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FinAware</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/finaware.css" asp-append-version="true" />
    <style>
        :root {
            --primary: #1AAFA3;
            --primary-dark: #0D7A71;
            --sidebar-w: 240px;
            --topbar-h: 56px;
            --transition: 0.25s cubic-bezier(.4,0,.2,1);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', system-ui, sans-serif;
            background: #f4f7f9;
            color: #1f2937;
            overflow-x: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: linear-gradient(180deg, #1AAFA3 0%, #0a6b65 100%);
            display: flex;
            flex-direction: column;
            z-index: 200;
            transition: transform var(--transition), width var(--transition);
            overflow: hidden;
        }

            .sidebar.collapsed {
                transform: translateX(calc(-1 * var(--sidebar-w)));
            }

            .sidebar::before {
                content: '';
                position: absolute;
                width: 200px;
                height: 200px;
                border-radius: 50%;
                background: rgba(255,255,255,0.05);
                top: -60px;
                right: -60px;
                pointer-events: none;
            }

            .sidebar::after {
                content: '';
                position: absolute;
                width: 150px;
                height: 150px;
                border-radius: 50%;
                background: rgba(255,255,255,0.04);
                bottom: 40px;
                left: -50px;
                pointer-events: none;
            }

        .sidebar-brand {
            padding: 18px 16px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            position: relative;
            z-index: 1;
            flex-shrink: 0;
        }

        .sidebar-brand-icon {
            width: 36px;
            height: 36px;
            background: rgba(255,255,255,0.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            border: 1px solid rgba(255,255,255,0.2);
        }

            .sidebar-brand-icon svg {
                width: 20px;
                height: 20px;
            }

        .sidebar-brand-text {
            display: flex;
            flex-direction: column;
            white-space: nowrap;
        }

        .sidebar-brand-name {
            font-size: 15px;
            font-weight: 700;
            color: white;
            letter-spacing: -0.3px;
            line-height: 1;
        }

        .sidebar-brand-tagline {
            font-size: 9px;
            color: rgba(255,255,255,0.6);
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-top: 2px;
        }

        .sidebar-user {
            padding: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            background: rgba(255,255,255,0.08);
            margin: 10px 10px 2px;
            border-radius: 12px;
            transition: background 0.2s;
            position: relative;
            z-index: 1;
            border: 1px solid rgba(255,255,255,0.1);
            flex-shrink: 0;
            white-space: nowrap;
        }

            .sidebar-user:hover {
                background: rgba(255,255,255,0.14);
            }

        .sidebar-avatar {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: rgba(255,255,255,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            color: white;
            flex-shrink: 0;
            overflow: hidden;
            border: 1.5px solid rgba(255,255,255,0.25);
        }

            .sidebar-avatar img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .sidebar-user-info {
            flex: 1;
            min-width: 0;
            overflow: hidden;
        }

        .sidebar-user-label {
            font-size: 10px;
            color: rgba(255,255,255,0.55);
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }

        .sidebar-user-name {
            font-size: 13px;
            font-weight: 600;
            color: white;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .sidebar-user-arrow {
            color: rgba(255,255,255,0.4);
            font-size: 11px;
        }

        .nav-section-label {
            font-size: 10px;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 10px 18px 4px;
            position: relative;
            z-index: 1;
            white-space: nowrap;
        }

        .nav-menu {
            flex: 1;
            padding: 4px 10px;
            overflow-y: auto;
            overflow-x: hidden;
            position: relative;
            z-index: 1;
        }

            .nav-menu::-webkit-scrollbar {
                width: 3px;
            }

            .nav-menu::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,0.2);
                border-radius: 2px;
            }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            color: rgba(255,255,255,0.75);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.18s;
            margin-bottom: 2px;
            white-space: nowrap;
        }

            .nav-link i {
                font-size: 16px;
                width: 18px;
                text-align: center;
                flex-shrink: 0;
            }

            .nav-link:hover {
                background: rgba(255,255,255,0.1);
                color: white;
            }

            .nav-link.active {
                background: rgba(255,255,255,0.18);
                color: white;
                font-weight: 600;
                box-shadow: inset 3px 0 0 white;
            }

        .sidebar-footer {
            padding: 10px;
            border-top: 1px solid rgba(255,255,255,0.1);
            position: relative;
            z-index: 1;
            flex-shrink: 0;
        }

        .btn-logout {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 9px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 10px;
            color: rgba(255,255,255,0.8);
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

            .btn-logout:hover {
                background: rgba(255,80,80,0.2);
                border-color: rgba(255,80,80,0.3);
                color: white;
            }

        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.4);
            z-index: 150;
            backdrop-filter: blur(2px);
        }

            .sidebar-overlay.visible {
                display: block;
            }

        /* MAIN */
        .main-wrapper {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: margin-left var(--transition);
        }

            .main-wrapper.expanded {
                margin-left: 0;
            }

        .topbar {
            background: white;
            border-bottom: 1px solid #e5e7eb;
            padding: 0 32px;
            height: var(--topbar-h);
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            gap: 16px;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .hamburger-btn {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            background: #f3f4f6;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.2s;
            flex-shrink: 0;
        }

            .hamburger-btn:hover {
                background: #e5e7eb;
            }

        .hamburger-lines {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

            .hamburger-lines span {
                display: block;
                width: 18px;
                height: 2px;
                background: #374151;
                border-radius: 1px;
                transition: all 0.25s;
            }

        .hamburger-btn.active .hamburger-lines span:nth-child(1) {
            transform: translateY(6px) rotate(45deg);
        }

        .hamburger-btn.active .hamburger-lines span:nth-child(2) {
            opacity: 0;
            transform: scaleX(0);
        }

        .hamburger-btn.active .hamburger-lines span:nth-child(3) {
            transform: translateY(-6px) rotate(-45deg);
        }

        .topbar-title {
            font-size: 15px;
            font-weight: 600;
            color: #111827;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-left: auto;
        }

        .notif-btn {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            background: #f3f4f6;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #374151;
            font-size: 16px;
            cursor: pointer;
            transition: background 0.2s;
            position: relative;
        }

            .notif-btn:hover {
                background: #e5e7eb;
            }

        .notif-badge {
            position: absolute;
            top: -3px;
            right: -3px;
            background: #ef4444;
            color: white;
            border-radius: 50%;
            width: 17px;
            height: 17px;
            font-size: 10px;
            font-weight: 700;
            display: none;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
        }

        .main-content {
            padding: 28px 40px 140px 40px;
            flex: 1;
        }

        .alert {
            border-radius: 12px;
            border: none;
            font-size: 14px;
            margin-bottom: 16px;
        }

        .dropdown-menu {
            border-radius: 14px !important;
            border: 1px solid #e5e7eb !important;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1) !important;
            padding: 6px !important;
        }

        .notif-item {
            padding: 9px 10px;
            border-radius: 9px;
            display: flex;
            gap: 10px;
            align-items: flex-start;
            text-decoration: none;
            color: inherit;
            transition: background 0.15s;
        }

            .notif-item:hover {
                background: #f9fafb;
            }

            .notif-item.unread {
                background: #f0fdf4;
            }

        /* FAB */
        .fab-container {
            position: fixed;
            bottom: 28px;
            right: 28px;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 12px;
        }

        .aris-btn {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            background: linear-gradient(135deg, #7C3AED 0%, #4F46E5 100%);
            border: none;
            box-shadow: 0 4px 16px rgba(124,58,237,0.4);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

            .aris-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(124,58,237,0.5);
            }

        .aris-label {
            position: absolute;
            right: 60px;
            top: 50%;
            transform: translateY(-50%);
            background: #4F46E5;
            color: white;
            font-size: 12px;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 8px;
            white-space: nowrap;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.2s;
        }

        .aris-btn:hover .aris-label {
            opacity: 1;
        }

        .fab-btn {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            background: linear-gradient(135deg, #1AAFA3 0%, #0D7A71 100%);
            border: none;
            box-shadow: 0 4px 16px rgba(26,175,163,0.4);
            color: white;
            font-size: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }

            .fab-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(26,175,163,0.5);
            }

        /* ARİS WIDGET */
        .aris-widget {
            position: fixed;
            bottom: 28px;
            right: 96px;
            width: 360px;
            height: 520px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            display: flex;
            flex-direction: column;
            z-index: 999;
            transform: scale(0.8) translateY(20px);
            opacity: 0;
            pointer-events: none;
            transform-origin: bottom right;
            transition: all 0.25s cubic-bezier(.4,0,.2,1);
        }

            .aris-widget.open {
                transform: scale(1) translateY(0);
                opacity: 1;
                pointer-events: all;
            }

        .aris-header {
            padding: 16px 20px;
            background: linear-gradient(135deg, #7C3AED 0%, #4F46E5 100%);
            border-radius: 20px 20px 0 0;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }

        .aris-avatar-wrap {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: rgba(255,255,255,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid rgba(255,255,255,0.25);
            flex-shrink: 0;
            overflow: hidden;
        }

        .aris-header-info {
            flex: 1;
        }

        .aris-header-name {
            font-size: 15px;
            font-weight: 700;
            color: white;
        }

        .aris-header-status {
            font-size: 11px;
            color: rgba(255,255,255,0.7);
        }

        .aris-close {
            background: rgba(255,255,255,0.15);
            border: none;
            color: white;
            width: 28px;
            height: 28px;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            transition: background 0.2s;
        }

            .aris-close:hover {
                background: rgba(255,255,255,0.25);
            }

        .aris-messages {
            flex: 1;
            padding: 16px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

            .aris-messages::-webkit-scrollbar {
                width: 3px;
            }

            .aris-messages::-webkit-scrollbar-thumb {
                background: #e5e7eb;
                border-radius: 2px;
            }

        .msg {
            display: flex;
            gap: 8px;
            align-items: flex-end;
        }

            .msg.user {
                flex-direction: row-reverse;
            }

        .msg-bubble {
            max-width: 78%;
            padding: 10px 14px;
            border-radius: 16px;
            font-size: 13px;
            line-height: 1.5;
        }

        .msg.aris .msg-bubble {
            background: #f3f4f6;
            color: #1f2937;
            border-radius: 4px 16px 16px 16px;
        }

        .msg.user .msg-bubble {
            background: linear-gradient(135deg,#7C3AED,#4F46E5);
            color: white;
            border-radius: 16px 4px 16px 16px;
        }

        .msg-icon {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: #7C3AED;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            overflow: hidden;
        }

        .aris-typing {
            display: flex;
            gap: 4px;
            align-items: center;
            padding: 10px 14px;
            background: #f3f4f6;
            border-radius: 4px 16px 16px 16px;
            width: fit-content;
        }

            .aris-typing span {
                width: 6px;
                height: 6px;
                background: #9ca3af;
                border-radius: 50%;
                animation: bounce 1.2s infinite;
            }

                .aris-typing span:nth-child(2) {
                    animation-delay: 0.2s;
                }

                .aris-typing span:nth-child(3) {
                    animation-delay: 0.4s;
                }

        @@keyframes bounce {
            0%, 60%, 100% {
                transform: translateY(0);
            }

            30% {
                transform: translateY(-6px);
            }
        }

        .aris-quick {
            padding: 0 16px 10px;
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            flex-shrink: 0;
        }

        .aris-chip {
            padding: 5px 10px;
            border-radius: 20px;
            border: 1.5px solid #e5e7eb;
            background: white;
            font-size: 11px;
            color: #374151;
            cursor: pointer;
            transition: all 0.15s;
            white-space: nowrap;
        }

            .aris-chip:hover {
                border-color: #7C3AED;
                color: #7C3AED;
                background: #f5f3ff;
            }

        .aris-input-area {
            padding: 12px 16px;
            border-top: 1px solid #f3f4f6;
            display: flex;
            gap: 8px;
            align-items: center;
            flex-shrink: 0;
        }

        .aris-input {
            flex: 1;
            border: 1.5px solid #e5e7eb;
            border-radius: 10px;
            padding: 9px 12px;
            font-size: 13px;
            outline: none;
            transition: border-color 0.2s;
            font-family: inherit;
        }

            .aris-input:focus {
                border-color: #7C3AED;
            }

        .aris-send {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: linear-gradient(135deg,#7C3AED,#4F46E5);
            border: none;
            color: white;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            flex-shrink: 0;
        }

            .aris-send:hover {
                transform: scale(1.05);
            }

            .aris-send:disabled {
                opacity: 0.5;
                cursor: not-allowed;
                transform: none;
            }

        /* RESPONSIVE */
        @@media (max-width: 768px) {
            .sidebar {
                transform: translateX(calc(-1 * var(--sidebar-w)));
            }

                .sidebar.mobile-open {
                    transform: translateX(0);
                }

            .main-wrapper {
                margin-left: 0 !important;
            }

            .main-content {
                padding: 20px 18px 140px 18px;
            }

            .topbar {
                padding: 0 18px;
            }

            .aris-widget {
                width: calc(100vw - 32px);
                right: 16px;
                bottom: 100px;
                height: 480px;
            }
        }
    </style>
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">
        <a href="/Dashboard/Index" style="text-decoration:none; display:block;">
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">
                <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="8" y="52" width="16" height="36" rx="4" fill="rgba(255,255,255,0.4)" />
                    <rect x="30" y="36" width="16" height="52" rx="4" fill="rgba(255,255,255,0.65)" />
                    <rect x="52" y="44" width="16" height="44" rx="4" fill="rgba(255,255,255,0.5)" />
                    <rect x="74" y="20" width="16" height="68" rx="4" fill="white" />
                    <polyline points="16,60 38,44 60,52 82,28" stroke="rgba(255,255,255,0.8)" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                    <circle cx="82" cy="28" r="5" fill="white" />
                </svg>
            </div>
            <div class="sidebar-brand-text">
                <span class="sidebar-brand-name">FinAware</span>
                <span class="sidebar-brand-tagline">Finansal Asistan</span>
            </div>
        </div>

        @{
            var username = Context.Session.GetString("Username") ?? "U";
            var profilePhoto = Context.Session.GetString("ProfilePhoto");
            var userRole = Context.Session.GetString("Role") ?? "User";
        }

        <a href="/Account/Index" class="sidebar-user">
            <div class="sidebar-avatar">
                @if (!string.IsNullOrEmpty(profilePhoto))
                {
                    <img src="@profilePhoto" alt="Profil" />
                }
                else
                {
                    @username.Substring(0, 1).ToUpper()
                }
            </div>
            <div class="sidebar-user-info">
                <div class="sidebar-user-label">Hesabım</div>
                <div class="sidebar-user-name">@username</div>
            </div>
            <i class="bi bi-chevron-right sidebar-user-arrow"></i>
        </a>

        <div class="nav-section-label">Menü</div>

        <div class="nav-menu">
            @if (userRole == "Admin")
            {
                <!-- Admin menüsü -->
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                   href="/Admin/Index">
                    <i class="bi bi-speedometer2"></i><span>Admin Paneli</span>
                </a>
            }
            else
            {
                <!-- Normal kullanıcı menüsü -->
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" href="/Dashboard/Index">
                    <i class="bi bi-house-door-fill"></i><span>Ana Sayfa</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transaction" ? "active" : "")" href="/Transaction/Index">
                    <i class="bi bi-arrow-left-right"></i><span>İşlemler</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Budget" ? "active" : "")" href="/Budget/Index">
                    <i class="bi bi-wallet2"></i><span>Bütçe</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Saving" ? "active" : "")" href="/Saving/Index">
                    <i class="bi bi-piggy-bank"></i><span>Birikimlerim</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analysis" ? "active" : "")" href="/Analysis/Index">
                    <i class="bi bi-bar-chart-line-fill"></i><span>Analiz</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")" href="/Category/Index">
                    <i class="bi bi-grid-fill"></i><span>Kategoriler</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "active" : "")" href="/Notification/Index">
                    <i class="bi bi-bell-fill"></i><span>Bildirimler</span>
                </a>
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Subscription" ? "active" : "")" href="/Subscription/Index">
                    <i class="bi bi-gem"></i><span>Planlar</span>
                </a>
            }
        </div>

        <div class="sidebar-footer">
            <form action="@Url.Action("Logout", "Auth")" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i>Çıkış Yap
                </button>
            </form>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main-wrapper" id="mainWrapper">
        <div class="topbar">
            <div class="topbar-left">
                <button class="hamburger-btn" id="hamburgerBtn" title="Menüyü Gizle/Göster">
                    <div class="hamburger-lines"><span></span><span></span><span></span></div>
                </button>
                <div class="topbar-title">@(ViewData["Title"] ?? "FinAware")</div>
            </div>
            <div class="topbar-right">
                <div class="dropdown">
                    <button class="notif-btn" type="button" id="notificationDropdown"
                            data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-bell"></i>
                        <span class="notif-badge" id="notificationBadge"></span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end"
                        style="width:340px;max-height:420px;overflow-y:auto;">
                        <li style="padding:8px 12px 4px;display:flex;justify-content:space-between;align-items:center;">
                            <span style="font-weight:600;font-size:14px;">Bildirimler</span>
                            <a href="/Notification/Index" style="font-size:12px;color:#1AAFA3;text-decoration:none;">Tümünü gör</a>
                        </li>
                        <li><hr style="margin:4px 0;border-color:#f3f4f6;"></li>
                        <li id="notificationList">
                            <div style="text-align:center;padding:16px;color:#9ca3af;font-size:13px;">Yükleniyor...</div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="main-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <!-- FAB -->
    @if (userRole != "Admin")
    {
        <div class="fab-container">
            <button class="aris-btn" id="arisToggle" title="ARİS ile konuş">
                <svg width="26" height="26" viewBox="0 0 38 38" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19 3 L33 9 L33 22 Q33 32 19 37 Q5 32 5 22 L5 9 Z"
                          fill="none" stroke="white" stroke-width="2.5" stroke-linejoin="round" />
                    <path d="M19 6 L30 11 L30 22 Q30 29 19 34 Q8 29 8 22 L8 11 Z"
                          fill="rgba(255,255,255,0.1)" />
                    <polyline points="10,25 14,19 18,22 22,16 26,18 31,11"
                              fill="none" stroke="white" stroke-width="2"
                              stroke-linecap="round" stroke-linejoin="round" />
                    <circle cx="22" cy="16" r="2" fill="white" />
                    <circle cx="31" cy="11" r="2.5" fill="white" />
                </svg>
                <span class="aris-label">ARİS</span>
            </button>
            <button class="fab-btn" data-bs-toggle="modal" data-bs-target="#addModal">
                <i class="bi bi-plus"></i>
            </button>
        </div>

        <!-- ARİS WIDGET -->
        <div class="aris-widget" id="arisWidget">
            <div class="aris-header">
                <div class="aris-avatar-wrap">
                    <svg width="32" height="32" viewBox="0 0 38 38" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19 2 L34 8 L34 21 Q34 31 19 37 Q4 31 4 21 L4 8 Z"
                              fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="2" stroke-linejoin="round" />
                        <path d="M19 5 L31 10 L31 21 Q31 28 19 34 Q7 28 7 21 L7 10 Z"
                              fill="rgba(255,255,255,0.12)" />
                        <polyline points="10,24 14,18 18,21 22,15 26,17 31,10"
                                  fill="none" stroke="rgba(255,255,255,0.95)"
                                  stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                        <circle cx="14" cy="18" r="1.5" fill="white" />
                        <circle cx="22" cy="15" r="1.5" fill="white" />
                        <circle cx="31" cy="10" r="2" fill="white" />
                    </svg>
                </div>
                <div class="aris-header-info">
                    <div class="aris-header-name">ARİS</div>
                    <div class="aris-header-status">Finansal Asistanın</div>
                </div>
                <button class="aris-close" id="arisClose">
                    <i class="bi bi-x"></i>
                </button>
            </div>
            <div class="aris-messages" id="arisMessages">
                <div class="msg aris">
                    <div class="msg-icon">
                        <svg width="18" height="18" viewBox="0 0 38 38" xmlns="http://www.w3.org/2000/svg">
                            <path d="M19 2 L34 8 L34 21 Q34 31 19 37 Q4 31 4 21 L4 8 Z"
                                  fill="none" stroke="white" stroke-width="2.5" stroke-linejoin="round" />
                            <polyline points="10,24 14,18 18,21 22,15 26,17 31,10"
                                      fill="none" stroke="white" stroke-width="2"
                                      stroke-linecap="round" stroke-linejoin="round" />
                            <circle cx="31" cy="10" r="2.5" fill="white" />
                        </svg>
                    </div>
                    <div class="msg-bubble">
                        Merhaba @username! Ben ARİS, finansal asistanın. Harcamalarını, bütçeni ve birikimlerini analiz edip sana özel tavsiyeler verebilirim. Ne öğrenmek istersin?
                    </div>
                </div>
            </div>
            <div class="aris-quick" id="arisQuick">
                <button class="aris-chip" onclick="arisQuickSend('Bu ay nasıl gidiyorum?')">Bu ay nasıl?</button>
                <button class="aris-chip" onclick="arisQuickSend('Nerede tasarruf edebilirim?')">Tasarruf öner</button>
                <button class="aris-chip" onclick="arisQuickSend('Birikimlerime götür')">Birikimlerim</button>
                <button class="aris-chip" onclick="arisQuickSend('İşlemler sayfasına git')">İşlemlerim</button>
                <button class="aris-chip" onclick="arisQuickSend('Bütçe durumum nasıl?')">Bütçem</button>
                <button class="aris-chip" onclick="arisQuickSend('Analiz sayfasına git')">Analiz</button>
            </div>
            <div class="aris-input-area">
                <input type="text" class="aris-input" id="arisInput"
                       placeholder="ARİS'e sor..." maxlength="300" />
                <button class="aris-send" id="arisSend">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
        </div>

        <!-- ADD MODAL -->
        <div class="modal fade" id="addModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius:20px;border:none;box-shadow:0 20px 60px rgba(0,0,0,0.15);">
                    <div class="modal-header" style="border:none;padding:24px 24px 0;">
                        <h5 class="modal-title fw-bold" style="font-size:18px;">Yeni Ekle</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body" style="padding:20px 24px 28px;">
                        <div class="row g-3">
                            <div class="col-6">
                                <a href="/Transaction/Create" class="text-decoration-none">
                                    <div style="border:2px solid #e5e7eb;border-radius:16px;padding:24px 16px;text-align:center;transition:all 0.2s;"
                                         onmouseover="this.style.borderColor='#1AAFA3';this.style.background='#f0fdf4'"
                                         onmouseout="this.style.borderColor='#e5e7eb';this.style.background='white'">
                                        <i class="bi bi-arrow-left-right" style="font-size:36px;color:#1AAFA3;display:block;margin-bottom:10px;"></i>
                                        <div style="font-weight:600;font-size:14px;color:#111827;">İşlem</div>
                                        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Gelir / Gider</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/Saving/Create" class="text-decoration-none">
                                    <div style="border:2px solid #e5e7eb;border-radius:16px;padding:24px 16px;text-align:center;transition:all 0.2s;"
                                         onmouseover="this.style.borderColor='#1AAFA3';this.style.background='#f0fdf4'"
                                         onmouseout="this.style.borderColor='#e5e7eb';this.style.background='white'">
                                        <i class="bi bi-piggy-bank" style="font-size:36px;color:#1AAFA3;display:block;margin-bottom:10px;"></i>
                                        <div style="font-weight:600;font-size:14px;color:#111827;">Birikim</div>
                                        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Hedef Oluştur</div>
                                    </div>
                                </a>
                            </div>
                            <div class="col-12">
                                <a href="/Budget/Index" class="text-decoration-none" data-bs-dismiss="modal">
                                    <div style="border:2px solid #e5e7eb;border-radius:16px;padding:20px 16px;text-align:center;transition:all 0.2s;"
                                         onmouseover="this.style.borderColor='#1AAFA3';this.style.background='#f0fdf4'"
                                         onmouseout="this.style.borderColor='#e5e7eb';this.style.background='white'">
                                        <i class="bi bi-wallet2" style="font-size:36px;color:#1AAFA3;display:block;margin-bottom:10px;"></i>
                                        <div style="font-weight:600;font-size:14px;color:#111827;">Bütçe Limiti</div>
                                        <div style="font-size:12px;color:#6b7280;margin-top:2px;">Kategori Bazlı Limit Belirle</div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Sidebar
        const sidebar      = document.getElementById('sidebar');
        const mainWrapper  = document.getElementById('mainWrapper');
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const overlay      = document.getElementById('sidebarOverlay');
        const isMobile     = () => window.innerWidth <= 768;
        let sidebarCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';

        function applySidebarState() {
            if (isMobile()) {
                sidebar.classList.remove('collapsed');
                mainWrapper.classList.remove('expanded');
                if (sidebarCollapsed) {
                    sidebar.classList.remove('mobile-open');
                    overlay.classList.remove('visible');
                } else {
                    sidebar.classList.add('mobile-open');
                    overlay.classList.add('visible');
                }
            } else {
                sidebar.classList.remove('mobile-open');
                overlay.classList.remove('visible');
                if (sidebarCollapsed) {
                    sidebar.classList.add('collapsed');
                    mainWrapper.classList.add('expanded');
                } else {
                    sidebar.classList.remove('collapsed');
                    mainWrapper.classList.remove('expanded');
                }
            }
            hamburgerBtn.classList.toggle('active', !sidebarCollapsed);
        }

        hamburgerBtn.addEventListener('click', () => {
            sidebarCollapsed = !sidebarCollapsed;
            if (!isMobile()) localStorage.setItem('sidebarCollapsed', sidebarCollapsed);
            applySidebarState();
        });
        overlay.addEventListener('click', () => { sidebarCollapsed = true; applySidebarState(); });
        window.addEventListener('resize', applySidebarState);
        if (isMobile()) sidebarCollapsed = true;
        applySidebarState();

        //  Bildirimler 
        let notificationsCache = [];
        async function loadNotifications() {
            try {
                const countRes  = await fetch('/Notification/GetUnreadCount');
                const countData = await countRes.json();
                const badge     = document.getElementById('notificationBadge');
                if (countData.count > 0) {
                    badge.textContent   = countData.count;
                    badge.style.display = 'flex';
                } else {
                    badge.style.display = 'none';
                }
                const notifRes = await fetch('/Notification/GetRecentNotifications');
                if (notifRes.ok) notificationsCache = await notifRes.json();
            } catch (e) { }
        }
        function showNotificationsInDropdown() {
            const list = document.getElementById('notificationList');
            if (!notificationsCache.length) {
                list.innerHTML = '<div style="text-align:center;padding:20px;color:#9ca3af;font-size:13px;">Henüz bildirim yok</div>';
                return;
            }
            list.innerHTML = notificationsCache.slice(0, 5).map(n => `
                <li>
                    <a class="notif-item ${n.isRead ? '' : 'unread'}" href="/Notification/Index">
                        <span style="font-size:20px;flex-shrink:0;">${n.icon}</span>
                        <div style="flex:1;min-width:0;">
                            <div style="font-weight:600;font-size:13px;color:#111827;">${n.title}</div>
                            <div style="font-size:12px;color:#6b7280;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${n.message}</div>
                        </div>
                    </a>
                </li>
            `).join('');
        }
        document.addEventListener('DOMContentLoaded', () => {
            loadNotifications();
            document.getElementById('notificationDropdown')
                ?.addEventListener('shown.bs.dropdown', showNotificationsInDropdown);
            setInterval(loadNotifications, 30000);
        });

        //  ARİS 
        const arisWidget   = document.getElementById('arisWidget');
        const arisToggle   = document.getElementById('arisToggle');
        const arisClose    = document.getElementById('arisClose');
        const arisInput    = document.getElementById('arisInput');
        const arisSend     = document.getElementById('arisSend');
        const arisMessages = document.getElementById('arisMessages');
        const arisQuick    = document.getElementById('arisQuick');
        let arisOpen = false;

        if (arisToggle) {
            arisToggle.addEventListener('click', () => {
                arisOpen = !arisOpen;
                arisWidget.classList.toggle('open', arisOpen);
                if (arisOpen) setTimeout(() => arisInput.focus(), 300);
            });
        }
        if (arisClose) {
            arisClose.addEventListener('click', () => {
                arisOpen = false;
                arisWidget.classList.remove('open');
            });
        }

        const arisIconHTML = `
            <svg width="18" height="18" viewBox="0 0 38 38" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 2 L34 8 L34 21 Q34 31 19 37 Q4 31 4 21 L4 8 Z"
                      fill="none" stroke="white" stroke-width="2.5" stroke-linejoin="round"/>
                <polyline points="10,24 14,18 18,21 22,15 26,17 31,10"
                          fill="none" stroke="white" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="31" cy="10" r="2.5" fill="white"/>
            </svg>`;

        function appendMessage(text, sender) {
            const msg = document.createElement('div');
            msg.className = `msg ${sender}`;
            if (sender === 'aris') {
                msg.innerHTML = `<div class="msg-icon">${arisIconHTML}</div>
                    <div class="msg-bubble">${text.replace(/\n/g, '<br>')}</div>`;
            } else {
                msg.innerHTML = `<div class="msg-bubble">${text}</div>`;
            }
            arisMessages.appendChild(msg);
            arisMessages.scrollTop = arisMessages.scrollHeight;
        }

        function showTyping() {
            const t = document.createElement('div');
            t.className = 'msg aris'; t.id = 'arisTyping';
            t.innerHTML = `<div class="msg-icon">${arisIconHTML}</div>
                <div class="aris-typing"><span></span><span></span><span></span></div>`;
            arisMessages.appendChild(t);
            arisMessages.scrollTop = arisMessages.scrollHeight;
        }
        function removeTyping() { document.getElementById('arisTyping')?.remove(); }

               async function sendToAris(message) {
            if (!message.trim() || arisSend?.disabled) return;
            if (arisQuick) arisQuick.style.display = 'none';
            appendMessage(message, 'user');
            if (arisInput) arisInput.value = '';
            showTyping();
            if (arisSend) arisSend.disabled = true;

            try {
                const res  = await fetch('/Aris/Chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message })
                });
                const data = await res.json();
                removeTyping();
                appendMessage(data.reply, 'aris');

                // Aksiyonu işle
                if (data.action) {
                    await handleArisAction(data.action);
                }
            } catch (e) {
                removeTyping();
                appendMessage('Bağlantı hatası, biraz sonra tekrar dene.', 'aris');
            } finally {
                if (arisSend) arisSend.disabled = false;
                if (arisInput) arisInput.focus();
            }
        }

        async function handleArisAction(action) {
            await new Promise(r => setTimeout(r, 800)); // Yanıtı okusun

            switch (action.type) {
                case 'navigate':
                    if (action.url) window.location.href = action.url;
                    break;

                case 'open_modal':
                    const modal = document.getElementById('addModal');
                    if (modal) new bootstrap.Modal(modal).show();
                    break;

                case 'add_transaction':
                case 'create_budget':
                case 'create_saving':
                case 'add_to_saving':
                    // Bunlar API'de zaten işlendi, sayfayı yenile
                    await new Promise(r => setTimeout(r, 500));
                    if (action.type === 'create_saving' || action.type === 'add_to_saving') {
                        appendMessage('Birikim sayfasına yönlendiriliyorsun...', 'aris');
                        setTimeout(() => window.location.href = '/Saving/Index', 1500);
                    } else if (action.type === 'create_budget') {
                        appendMessage('Bütçe sayfasına yönlendiriliyorsun...', 'aris');
                        setTimeout(() => window.location.href = '/Budget/Index', 1500);
                    } else {
                        appendMessage('İşlem eklendi! Sayfa yenileniyor...', 'aris');
                        setTimeout(() => window.location.reload(), 1500);
                    }
                    break;
            }
        }

        arisSend?.addEventListener('click', () => sendToAris(arisInput.value));
        arisInput?.addEventListener('keydown', e => {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendToAris(arisInput.value); }
        });
        function arisQuickSend(msg) { sendToAris(msg); }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
