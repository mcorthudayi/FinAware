@{
    ViewData["Title"] = "Ödeme";
}

<div style="max-width:600px;margin:40px auto;text-align:center;">
    <div style="background:white;border-radius:20px;padding:32px;box-shadow:0 8px 32px rgba(0,0,0,0.08);">
        <div style="font-size:32px;margin-bottom:12px;">💳</div>
        <h4 style="font-weight:700;color:#111827;">@ViewBag.Plan Planı — Ödeme</h4>
        <p style="color:#6b7280;font-size:13px;margin-bottom:24px;">
            Güvenli ödeme İyzico altyapısı ile gerçekleştirilmektedir.
        </p>
        <div id="iyzipay-checkout-form" class="responsive">
            @Html.Raw(ViewBag.CheckoutFormContent)
        </div>
    </div>
</div>