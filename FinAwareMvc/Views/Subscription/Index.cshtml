@{
    ViewData["Title"] = "Planlar";
    string currentPlan = "Free";
    string? expiry = null;
    int ocrUsage = 0;
    int arisUsage = 0;

    var myPlanJson = ViewBag.MyPlanJson as string;
    if (!string.IsNullOrEmpty(myPlanJson))
    {
        try
        {
            var el = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(myPlanJson);
            currentPlan = el.TryGetProperty("plan", out var p) ? p.GetString() ?? "Free" : "Free";
            expiry = el.TryGetProperty("expiry", out var ex) ? ex.GetString() : null;
            ocrUsage = el.TryGetProperty("ocrUsage", out var ou) ? ou.GetInt32() : 0;
            arisUsage = el.TryGetProperty("arisUsage", out var au) ? au.GetInt32() : 0;
        }
        catch { }
    }
}

<style>
    .pricing-hero {
        text-align: center;
        padding: 40px 0 48px;
    }

        .pricing-hero h1 {
            font-size: 36px;
            font-weight: 800;
            color: #111827;
            margin-bottom: 12px;
        }

        .pricing-hero p {
            font-size: 16px;
            color: #6b7280;
            max-width: 480px;
            margin: 0 auto;
        }

    .pricing-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 24px;
        max-width: 960px;
        margin: 0 auto;
    }

    .pricing-card {
        background: white;
        border-radius: 20px;
        border: 2px solid #e5e7eb;
        padding: 32px 28px;
        position: relative;
        transition: all 0.2s;
    }

        .pricing-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 40px rgba(0,0,0,0.1);
        }

        .pricing-card.popular {
            border-color: #1AAFA3;
            box-shadow: 0 8px 32px rgba(26,175,163,0.15);
        }

        .pricing-card.current-plan {
            border-color: #7c3aed;
        }

    .top-badge {
        position: absolute;
        top: -14px;
        left: 50%;
        transform: translateX(-50%);
        color: white;
        font-size: 11px;
        font-weight: 700;
        padding: 4px 14px;
        border-radius: 20px;
        white-space: nowrap;
        letter-spacing: 0.5px;
    }

    .badge-popular {
        background: linear-gradient(135deg,#1AAFA3,#0D7A71);
    }

    .badge-current {
        background: linear-gradient(135deg,#7c3aed,#4f46e5);
    }

    .plan-icon {
        font-size: 36px;
        margin-bottom: 12px;
    }

    .plan-name {
        font-size: 20px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 4px;
    }

    .plan-price {
        font-size: 40px;
        font-weight: 800;
        color: #111827;
        line-height: 1;
    }

        .plan-price span {
            font-size: 16px;
            font-weight: 500;
            color: #6b7280;
        }

    .plan-desc {
        font-size: 13px;
        color: #6b7280;
        margin: 8px 0 24px;
    }

    .plan-features {
        list-style: none;
        padding: 0;
        margin: 0 0 28px;
    }

        .plan-features li {
            font-size: 13px;
            color: #374151;
            padding: 7px 0;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid #f9fafb;
        }

            .plan-features li:last-child {
                border: none;
            }

    .feat-check {
        color: #1AAFA3;
        font-size: 15px;
        flex-shrink: 0;
    }

    .feat-cross {
        color: #d1d5db;
        font-size: 15px;
        flex-shrink: 0;
    }

    .feat-text-muted {
        color: #9ca3af;
    }

    /* Tooltip */
    .feat-tip {
        position: relative;
        cursor: help;
        border-bottom: 1px dashed #d1d5db;
    }

        .feat-tip::after {
            content: attr(data-tip);
            position: absolute;
            left: 0;
            top: 120%;
            background: #111827;
            color: white;
            font-size: 12px;
            line-height: 1.5;
            padding: 8px 12px;
            border-radius: 10px;
            white-space: normal;
            width: 220px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.2s;
            z-index: 999;
        }

        .feat-tip:hover::after {
            opacity: 1;
        }

    .btn-subscribe {
        width: 100%;
        padding: 13px;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-subscribe:hover:not(:disabled) {
            opacity: 0.9;
            transform: translateY(-1px);
        }

    .btn-free {
        background: #f3f4f6;
        color: #374151;
    }

    .btn-gold {
        background: linear-gradient(135deg,#f59e0b,#d97706);
        color: white;
    }

    .btn-platinum {
        background: linear-gradient(135deg,#7c3aed,#4f46e5);
        color: white;
    }

    .btn-current {
        background: #f3f4f6;
        color: #9ca3af;
        cursor: not-allowed;
    }

    .usage-bar {
        background: #f3f4f6;
        border-radius: 8px;
        height: 6px;
        overflow: hidden;
        margin-top: 4px;
    }

    .usage-fill {
        height: 100%;
        border-radius: 8px;
        background: linear-gradient(90deg,#1AAFA3,#0D7A71);
        transition: width 0.5s;
    }

    .faq-section {
        max-width: 680px;
        margin: 60px auto 0;
    }

    .faq-item {
        border-bottom: 1px solid #f3f4f6;
        padding: 20px 0;
    }

    .faq-q {
        font-size: 15px;
        font-weight: 600;
        color: #111827;
        margin-bottom: 8px;
    }

    .faq-a {
        font-size: 13px;
        color: #6b7280;
        line-height: 1.7;
    }

    .secure-badge {
        text-align: center;
        margin-top: 24px;
        font-size: 12px;
        color: #9ca3af;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    @@media (max-width:768px) {
        .pricing-grid {
            grid-template-columns: 1fr;
        }

        .pricing-hero h1 {
            font-size: 26px;
        }
    }
</style>

<!-- Hero -->
<div class="pricing-hero">
    <h1>Sana Uygun Planı Seç</h1>
    <p>Finansal hedeflerine ulaşmak için ihtiyacın olan her şey burada.</p>

    <div style="margin-top:16px;display:inline-flex;align-items:center;gap:8px;
                background:#f0fdf9;border:1px solid #1AAFA3;border-radius:20px;
                padding:6px 16px;font-size:13px;color:#1AAFA3;font-weight:600;">
        <i class="bi bi-check-circle-fill"></i>
        Mevcut planın: @currentPlan
        @if (!string.IsNullOrEmpty(expiry))
        {
            <span style="color:#6b7280;font-weight:400;">— @expiry tarihine kadar</span>
        }
    </div>
</div>

<!-- Gold kullanım göstergesi -->
@if (currentPlan == "Gold")
{
    <div style="max-width:480px;margin:0 auto 32px;background:white;border-radius:16px;padding:20px;border:1px solid #e5e7eb;">
        <div style="font-size:13px;font-weight:600;color:#374151;margin-bottom:12px;">Bu Ayki Kullanımın</div>
        <div style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;font-size:12px;color:#6b7280;margin-bottom:4px;">
                <span>Fatura OCR</span><span>@ocrUsage / 60</span>
            </div>
            <div class="usage-bar"><div class="usage-fill" style="width:@(Math.Min(ocrUsage * 100 / 60, 100))%"></div></div>
        </div>
        <div>
            <div style="display:flex;justify-content:space-between;font-size:12px;color:#6b7280;margin-bottom:4px;">
                <span>ARİS Soru</span><span>@arisUsage / 30</span>
            </div>
            <div class="usage-bar"><div class="usage-fill" style="width:@(Math.Min(arisUsage * 100 / 30, 100))%"></div></div>
        </div>
    </div>
}

<!-- Pricing Grid -->
<div class="pricing-grid">

    <!-- FREE -->
    <div class="pricing-card @(currentPlan == "Free" ? "current-plan" : "")">
        @if (currentPlan == "Free")
        {
            <div class="top-badge badge-current">Mevcut Planın</div>
        }
        <div class="plan-icon">🆓</div>
        <div class="plan-name">Free</div>
        <div class="plan-price">₺0 <span>/ ay</span></div>
        <div class="plan-desc">Başlamak için mükemmel</div>
        <ul class="plan-features">
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Gelir, gider ve transfer işlemlerini dilediğin kadar ekleyebilirsin.">Sınırsız manuel işlem</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Aylık harcama limitleri belirle, bütçeni takip et.">Sınırsız bütçe planı</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Tatil, araba, ev gibi hedefler koy ve düzenli birikim yap.">Sınırsız birikim hedefi</span>
            </li>
            <li>
                <i class="bi bi-x-circle-fill feat-cross"></i>
                <span class="feat-tip feat-text-muted" data-tip="Tüm işlemlerini .xlsx formatında dışa aktarıp bilgisayarına indirebilirsin.">Excel dışa aktarma</span>
            </li>
            <li>
                <i class="bi bi-x-circle-fill feat-cross"></i>
                <span class="feat-tip feat-text-muted" data-tip="Telegram'dan bakiye sorgula, işlem ekle, bütçe ve birikim takibi yap.">Telegram Bot</span>
            </li>
            <li>
                <i class="bi bi-x-circle-fill feat-cross"></i>
                <span class="feat-tip feat-text-muted" data-tip="Fatura veya fiş fotoğrafı gönder, yapay zeka tutarı ve kategoriyi otomatik okusun.">Fatura OCR</span>
            </li>
            <li>
                <i class="bi bi-x-circle-fill feat-cross"></i>
                <span class="feat-tip feat-text-muted" data-tip="ARİS finansal asistanına harcama analizi, tasarruf önerisi ve daha fazlasını sorabilirsin.">ARİS Asistan</span>
            </li>
        </ul>
        <button class="btn-subscribe btn-current" disabled>
            @(currentPlan == "Free" ? "Mevcut Planın" : "Ücretsiz")
        </button>
    </div>

    <!-- GOLD -->
    <div class="pricing-card popular @(currentPlan == "Gold" ? "current-plan" : "")">
        @if (currentPlan == "Gold")
        {
            <div class="top-badge badge-current">Mevcut Planın</div>
        }
        else
        {

            <div class="top-badge badge-popular">En Popüler</div>
        }
        <div class="plan-icon">🥇</div>
        <div class="plan-name" style="color:#d97706;">Gold</div>
        <div class="plan-price">₺75 <span>/ ay</span></div>
        <div class="plan-desc">Aktif kullanıcılar için ideal</div>
        <ul class="plan-features">
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Gelir, gider ve transfer işlemlerini dilediğin kadar ekleyebilirsin.">Sınırsız manuel işlem</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Aylık harcama limitleri belirle, bütçeni takip et.">Sınırsız bütçe planı</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Tatil, araba, ev gibi hedefler koy ve düzenli birikim yap.">Sınırsız birikim hedefi</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Tüm işlemlerini .xlsx formatında dışa aktarıp bilgisayarına indirebilirsin.">Excel dışa aktarma</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Telegram'dan bakiye sorgula, işlem ekle, bütçe ve birikim takibi yap.">Telegram Bot</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Ayda 60 fatura/fiş fotoğrafı analiz edebilirsin. Yapay zeka tutarı ve kategoriyi otomatik algılar.">Fatura OCR (60/ay)</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="ARİS'e ayda 30 soru sorabilirsin. Harcama analizi, tasarruf önerisi, işlem ekleme ve daha fazlası.">ARİS Asistan (30 soru/ay)</span>
            </li>
        </ul>
        @if (currentPlan == "Gold")
        {
            <button class="btn-subscribe btn-current" disabled>Mevcut Planın</button>
            <form method="post" action="/Subscription/Cancel" style="margin-top:8px;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-subscribe btn-free"
                        onclick="return confirm('Aboneliğini iptal etmek istediğine emin misin?')">
                    İptal Et
                </button>
            </form>
        }
        else
        {
            <form method="post" action="/Subscription/Subscribe" onsubmit="handleSubmit(this,'gold-btn')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="plan" value="Gold" />
                <button type="submit" id="gold-btn" class="btn-subscribe btn-gold">Gold'a Geç →</button>
            </form>
        }
    </div>

    <!-- PLATINUM -->
    <div class="pricing-card @(currentPlan == "Platinum" ? "current-plan" : "")">
        @if (currentPlan == "Platinum")
        {
            <div class="top-badge badge-current">Mevcut Planın</div>
        }
        <div class="plan-icon">💎</div>
        <div class="plan-name" style="color:#7c3aed;">Platinum</div>
        <div class="plan-price">₺200 <span>/ ay</span></div>
        <div class="plan-desc">Her şey sınırsız, pro seviye</div>
        <ul class="plan-features">
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Gelir, gider ve transfer işlemlerini dilediğin kadar ekleyebilirsin.">Sınırsız manuel işlem</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Aylık harcama limitleri belirle, bütçeni takip et.">Sınırsız bütçe planı</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Tatil, araba, ev gibi hedefler koy ve düzenli birikim yap.">Sınırsız birikim hedefi</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Tüm işlemlerini .xlsx formatında dışa aktarıp bilgisayarına indirebilirsin.">Excel dışa aktarma</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Telegram'dan bakiye sorgula, işlem ekle, bütçe ve birikim takibi yap.">Telegram Bot</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="Sınırsız fatura/fiş analizi. Yapay zeka tutarı ve kategoriyi otomatik algılar, işlemi ekler.">Fatura OCR (sınırsız)</span>
            </li>
            <li>
                <i class="bi bi-check-circle-fill feat-check"></i>
                <span class="feat-tip" data-tip="ARİS'e sınırsız soru sor. İşlem ekle, bütçe kur, analiz al, sayfalar arası gezin.">ARİS Asistan (sınırsız)</span>
            </li>
        </ul>
        @if (currentPlan == "Platinum")
        {
            <button class="btn-subscribe btn-current" disabled>Mevcut Planın</button>
            <form method="post" action="/Subscription/Cancel" style="margin-top:8px;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-subscribe btn-free"
                        onclick="return confirm('Aboneliğini iptal etmek istediğine emin misin?')">
                    İptal Et
                </button>
            </form>
        }
        else
        {
            <form method="post" action="/Subscription/Subscribe" onsubmit="handleSubmit(this,'plat-btn')">
                @Html.AntiForgeryToken()
                <input type="hidden" name="plan" value="Platinum" />
                <button type="submit" id="plat-btn" class="btn-subscribe btn-platinum">Platinum'a Geç →</button>
            </form>
        }
    </div>
</div>

<!-- Güvenlik badgei -->
<div class="secure-badge">
    <i class="bi bi-shield-check" style="color:#1AAFA3;font-size:14px;"></i>
    Ödemeler İyzico altyapısı ile güvenle işleniyor. Kart bilgileri FinAware'e iletilmez.
</div>

<!-- FAQ -->
<div class="faq-section">
    <h3 style="font-size:22px;font-weight:700;color:#111827;text-align:center;margin-bottom:24px;">Sık Sorulan Sorular</h3>
    <div class="faq-item">
        <div class="faq-q">Aboneliğimi istediğim zaman iptal edebilir miyim?</div>
        <div class="faq-a">Evet, aboneliğini her zaman iptal edebilirsin. İptal ettiğinde mevcut dönem sonuna kadar planın aktif kalmaya devam eder.</div>
    </div>
    <div class="faq-item">
        <div class="faq-q">OCR ve ARİS limitleri ne zaman sıfırlanır?</div>
        <div class="faq-a">Her ayın başında otomatik olarak sıfırlanır.</div>
    </div>
    <div class="faq-item">
        <div class="faq-q">Fatura OCR tam olarak nasıl çalışıyor?</div>
        <div class="faq-a">Fatura veya fiş fotoğrafını yükle ya da Telegram'dan gönder. Yapay zeka tutarı, tarihi ve kategoriyi otomatik algılar ve işlemi hesabına ekler. Onaylamandan eklemez.</div>
    </div>
    <div class="faq-item">
        <div class="faq-q">ARİS ne yapabilir?</div>
        <div class="faq-a">ARİS finansal asistanın; harcama analizi yapar, tasarruf önerir, işlem ekler, bütçe ve birikim oluşturur, istediğin sayfaya götürür. Doğal dille konuşarak finansını yönetebilirsin.</div>
    </div>
    <div class="faq-item">
        <div class="faq-q">Gold'dan Platinum'a geçebilir miyim?</div>
        <div class="faq-a">Evet, istediğin zaman planını yükseltebilirsin.</div>
    </div>
    <div class="faq-item">
        <div class="faq-q">Ödeme güvenli mi?</div>
        <div class="faq-a">Tüm ödemeler İyzico altyapısı üzerinden SSL korumalı olarak gerçekleştirilir. Kart bilgilerin bizde saklanmaz.</div>
    </div>
</div>

@section Scripts {
    <script>
        function handleSubmit(form, btnId) {
            const btn = document.getElementById(btnId);
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Yönlendiriliyor...';
            }
            return true;
        }
    </script>
}
