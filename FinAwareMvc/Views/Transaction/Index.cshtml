@model List<FinAware.MVC.Models.ViewModels.TransactionViewModel>
@{
    ViewData["Title"] = "İşlemler";
    var culture = new System.Globalization.CultureInfo("tr-TR");
    var now = DateTime.Now;

    int selectedMonth = Context.Request.Query.ContainsKey("month")
        ? int.Parse(Context.Request.Query["month"]!) : now.Month;
    int selectedYear = Context.Request.Query.ContainsKey("year")
        ? int.Parse(Context.Request.Query["year"]!) : now.Year;

    var filtered = Model
        .Where(t => t.Date.Month == selectedMonth && t.Date.Year == selectedYear)
        .OrderByDescending(t => t.Date)
        .ToList();

    decimal monthIncome  = filtered.Where(t => t.Type == "Income").Sum(t => t.Amount);
    decimal monthExpense = filtered.Where(t => t.Type == "Expense").Sum(t => t.Amount);
    decimal monthBalance = monthIncome - monthExpense;

    var selectedDate   = new DateTime(selectedYear, selectedMonth, 1);
    var prevDate       = selectedDate.AddMonths(-1);
    var nextDate       = selectedDate.AddMonths(1);
    bool isCurrentMonth = selectedMonth == now.Month && selectedYear == now.Year;

    var grouped = filtered
        .GroupBy(t => t.Date.Date)
        .OrderByDescending(g => g.Key)
        .ToList();

    string MonthName(DateTime d) => d.ToString("MMMM yyyy", culture);
    string DayLabel(DateTime d)
    {
        if (d.Date == now.Date) return "Bugün";
        if (d.Date == now.Date.AddDays(-1)) return "Dün";
        return d.ToString("dd MMMM, dddd", culture);
    }
}

<style>
    /* AY NAVİGASYONU */
    .month-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        gap: 12px;
    }
    .month-nav-center {
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .month-nav-btn {
        width: 38px; height: 38px;
        border-radius: 12px;
        background: white;
        border: 1.5px solid var(--border-color, #e5e7eb);
        display: flex; align-items: center; justify-content: center;
        color: #374151; font-size: 16px;
        cursor: pointer; transition: all 0.18s;
        text-decoration: none;
        flex-shrink: 0;
    }
    .month-nav-btn:hover {
        background: var(--primary, #1AAFA3);
        border-color: var(--primary, #1AAFA3);
        color: white;
    }
    .month-nav-btn.disabled {
        opacity: 0.3;
        pointer-events: none;
    }
    .month-title {
        font-size: 18px; font-weight: 800;
        color: var(--text-primary, #111827);
        min-width: 170px; text-align: center;
        letter-spacing: -0.3px;
    }
    .btn-add-tx {
        background: linear-gradient(135deg, #1AAFA3 0%, #0D7A71 100%);
        color: white; border: none;
        border-radius: 12px; padding: 10px 18px;
        font-weight: 700; font-size: 14px;
        text-decoration: none;
        display: flex; align-items: center; gap: 6px;
        transition: all 0.2s; flex-shrink: 0;
    }
    .btn-add-tx:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(26,175,163,0.35);
        color: white;
    }

    /* ÖZET KARTLAR */
    .summary-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 20px;
    }
    .summary-card {
        background: white;
        border-radius: 16px;
        padding: 16px 18px;
        border: 1.5px solid var(--border-color, #e5e7eb);
        display: flex; align-items: center;
        justify-content: space-between;
        transition: all 0.2s;
    }
    .summary-card.clickable { cursor: pointer; }
    .summary-card.clickable:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        border-color: #1AAFA3;
    }
    .summary-card-label {
        font-size: 12px; color: #6b7280; margin-bottom: 4px;
    }
    .summary-card-amount {
        font-size: 20px; font-weight: 800; letter-spacing: -0.3px;
    }
    .summary-card-icon {
        width: 44px; height: 44px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; flex-shrink: 0;
    }

    /* FİLTRE BAR */
    .filter-bar {
        display: flex; gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap; align-items: center;
    }
    .search-wrapper { position: relative; flex: 1; min-width: 180px; }
    .search-wrapper i {
        position: absolute; left: 12px; top: 50%;
        transform: translateY(-50%);
        color: #9ca3af; font-size: 14px;
    }
    .filter-search {
        width: 100%;
        padding: 10px 14px 10px 36px;
        border: 1.5px solid var(--border-color, #e5e7eb);
        border-radius: 12px;
        font-size: 14px; background: white;
        transition: border-color 0.15s;
    }
    .filter-search:focus {
        outline: none; border-color: #1AAFA3;
        box-shadow: 0 0 0 3px rgba(26,175,163,0.1);
    }
    .filter-btn {
        padding: 10px 16px; border-radius: 12px;
        border: 1.5px solid var(--border-color, #e5e7eb);
        background: white; font-size: 13px; font-weight: 600;
        color: #374151; cursor: pointer; transition: all 0.18s;
    }
    .filter-btn.active {
        background: #1AAFA3; border-color: #1AAFA3; color: white;
    }
    .filter-btn:hover:not(.active) {
        border-color: #1AAFA3; color: #1AAFA3;
    }

    /* GÜN GRUBU */
    .day-group { margin-bottom: 20px; }
    .day-label {
        font-size: 11px; font-weight: 700;
        color: #9ca3af; text-transform: uppercase;
        letter-spacing: 0.8px; padding: 0 4px;
        margin-bottom: 8px;
        display: flex; align-items: center; gap: 8px;
    }
    .day-label::after {
        content: ''; flex: 1; height: 1px; background: #f3f4f6;
    }

    /* İŞLEM KARTI */
    .tx-card {
        background: white;
        border-radius: 14px;
        border: 1.5px solid var(--border-color, #f3f4f6);
        padding: 13px 16px;
        margin-bottom: 8px;
        display: flex; align-items: center; gap: 14px;
        transition: all 0.18s;
    }
    .tx-card:hover {
        box-shadow: 0 4px 16px rgba(0,0,0,0.07);
        border-color: #e5e7eb;
    }
    .tx-icon {
        width: 44px; height: 44px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; flex-shrink: 0;
    }
    .tx-info { flex: 1; min-width: 0; }
    .tx-name {
        font-size: 14px; font-weight: 600;
        color: var(--text-primary, #111827);
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .tx-meta { font-size: 12px; color: #9ca3af; margin-top: 2px; }
    .tx-fx { font-size: 11px; color: #1AAFA3; font-weight: 600; margin-left: 6px; }
    .tx-amount {
        font-size: 15px; font-weight: 800;
        flex-shrink: 0; text-align: right;
    }
    .tx-amount.income { color: #10b981; }
    .tx-amount.expense { color: #ef4444; }
    .tx-original {
        font-size: 11px; color: #9ca3af; display: block; font-weight: 400;
    }
    .tx-actions {
        display: flex; gap: 6px; flex-shrink: 0;
        opacity: 0; transition: opacity 0.18s;
    }
    .tx-card:hover .tx-actions { opacity: 1; }
    .tx-action-btn {
        width: 32px; height: 32px; border-radius: 9px;
        border: 1.5px solid #e5e7eb; background: white;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 13px;
        transition: all 0.15s;
        text-decoration: none; color: #6b7280;
    }
    .tx-action-btn.edit:hover {
        border-color: #1AAFA3; color: #1AAFA3; background: #E8F7F6;
    }
    .tx-action-btn.delete:hover {
        border-color: #ef4444; color: #ef4444; background: #fef2f2;
    }

    /* BOŞ STATE */
    .empty-month {
        text-align: center; padding: 60px 24px;
        background: white; border-radius: 20px;
        border: 1.5px solid var(--border-color, #e5e7eb);
    }
    .empty-month-icon { font-size: 48px; margin-bottom: 12px; }
    .empty-month-title { font-size: 16px; font-weight: 700; color: #6b7280; margin-bottom: 6px; }
    .empty-month-sub { font-size: 14px; color: #9ca3af; }

    @@media (max-width: 640px) {
        .summary-cards { grid-template-columns: 1fr 1fr; }
        .tx-actions { opacity: 1; }
        .month-title { min-width: auto; font-size: 15px; }
    }
</style>

<!-- AY NAVİGASYONU -->
<div class="month-nav">
    <div class="month-nav-center">
        <a class="month-nav-btn" href="/Transaction/Index?month=@prevDate.Month&year=@prevDate.Year">
            <i class="bi bi-chevron-left"></i>
        </a>
        <div class="month-title">@MonthName(selectedDate)</div>
        <a class="month-nav-btn @(isCurrentMonth ? "disabled" : "")"
           href="/Transaction/Index?month=@nextDate.Month&year=@nextDate.Year">
            <i class="bi bi-chevron-right"></i>
        </a>
    </div>
    <a href="/Transaction/Create" class="btn-add-tx">
        <i class="bi bi-plus-lg"></i> İşlem Ekle
    </a>
</div>

<!-- ÖZET KARTLAR -->
<div class="summary-cards">
    <div class="summary-card clickable" onclick="window.location.href='/Transaction/Create?type=Income'" title="Gelir ekle">
        <div>
            <div class="summary-card-label">Gelir</div>
            <div class="summary-card-amount" style="color:#10b981;">+₺@monthIncome.ToString("N2", culture)</div>
        </div>
        <div class="summary-card-icon" style="background:#ecfdf5;">
            <i class="bi bi-arrow-down-circle" style="color:#10b981;"></i>
        </div>
    </div>
    <div class="summary-card clickable" onclick="window.location.href='/Transaction/Create?type=Expense'" title="Gider ekle">
        <div>
            <div class="summary-card-label">Gider</div>
            <div class="summary-card-amount" style="color:#ef4444;">-₺@monthExpense.ToString("N2", culture)</div>
        </div>
        <div class="summary-card-icon" style="background:#fef2f2;">
            <i class="bi bi-arrow-up-circle" style="color:#ef4444;"></i>
        </div>
    </div>
    <div class="summary-card">
        <div>
            <div class="summary-card-label">Net Bakiye</div>
            <div class="summary-card-amount" style="color:@(monthBalance >= 0 ? "#1AAFA3" : "#ef4444");">
                @(monthBalance >= 0 ? "+" : "")₺@monthBalance.ToString("N2", culture)
            </div>
        </div>
        <div class="summary-card-icon" style="background:#E8F7F6;">
            <i class="bi bi-wallet2" style="color:#1AAFA3;"></i>
        </div>
    </div>
</div>

<!-- FİLTRE BAR -->
<div class="filter-bar">
    <div class="search-wrapper">
        <i class="bi bi-search"></i>
        <input type="text" class="filter-search" id="searchInput"
               placeholder="İşlem ara..." oninput="filterTransactions()" />
    </div>
    <button class="filter-btn active" onclick="setFilter('all', this)">Tümü</button>
    <button class="filter-btn" onclick="setFilter('Income', this)">💰 Gelir</button>
    <button class="filter-btn" onclick="setFilter('Expense', this)">💸 Gider</button>
</div>

<!-- İŞLEMLER LİSTESİ -->
<div id="transactionsList">
    @if (!grouped.Any())
    {
        <div class="empty-month">
            <div class="empty-month-icon">📭</div>
            <div class="empty-month-title">Bu ayda işlem yok</div>
            <div class="empty-month-sub">+ butonuyla yeni işlem ekleyebilirsin</div>
        </div>
    }
    else
    {
        foreach (var group in grouped)
        {
            <div class="day-group" data-day="@group.Key.ToString("yyyy-MM-dd")">
                <div class="day-label">@DayLabel(group.Key)</div>

                @foreach (var t in group)
                {
                    bool isIncome = t.Type == "Income";
                    bool hasFx    = t.OriginalCurrency != "TRY" && t.OriginalCurrency != null;

                    <div class="tx-card"
                         data-type="@t.Type"
                         data-search="@((t.Description + " " + t.CategoryName).ToLower())">

                        <div class="tx-icon" style="background:@(isIncome ? "#ecfdf5" : "#fef2f2");">
                            @(t.CategoryIcon ?? "💳")
                        </div>

                        <div class="tx-info">
                            <div class="tx-name">
                                @(string.IsNullOrEmpty(t.Description) ? t.CategoryName : t.Description)
                            </div>
                            <div class="tx-meta">
                                @t.CategoryName
                                @if (hasFx)
                                {
                                    <span class="tx-fx">· @t.OriginalAmount?.ToString("N4") @t.OriginalCurrency</span>
                                }
                                · @t.Date.ToString("HH:mm")
                            </div>
                        </div>

                        <div class="tx-amount @(isIncome ? "income" : "expense")">
                            @(isIncome ? "+" : "-")₺@t.Amount.ToString("N2", culture)
                            @if (hasFx)
                            {
                                <span class="tx-original">Kur: @t.ExchangeRate?.ToString("N4")</span>
                            }
                        </div>

                        <div class="tx-actions">
                            <a href="/Transaction/Edit/@t.TransactionId" class="tx-action-btn edit" title="Düzenle">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="/Transaction/Delete/@t.TransactionId"
                                  onsubmit="return confirm('Bu işlemi silmek istediğine emin misin?')"
                                  style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="tx-action-btn delete" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        let currentFilter = 'all';

        function setFilter(type, btn) {
            currentFilter = type;
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            filterTransactions();
        }

        function filterTransactions() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            document.querySelectorAll('.tx-card').forEach(card => {
                const typeMatch   = currentFilter === 'all' || card.dataset.type === currentFilter;
                const searchMatch = !search || card.dataset.search.includes(search);
                card.style.display = (typeMatch && searchMatch) ? 'flex' : 'none';
            });
            document.querySelectorAll('.day-group').forEach(group => {
                const hasVisible = Array.from(group.querySelectorAll('.tx-card'))
                    .some(c => c.style.display !== 'none');
                group.style.display = hasVisible ? 'block' : 'none';
            });
        }
    </script>
}
