@model List<FinAware.MVC.Models.ViewModels.TransactionViewModel>
@{
    ViewData["Title"] = "İşlemler";
    var culture = new System.Globalization.CultureInfo("tr-TR");
    var now = DateTime.Now;

    // URL'den ay/yıl parametresi al
    int selectedMonth = Context.Request.Query.ContainsKey("month")
        ? int.Parse(Context.Request.Query["month"]!) : now.Month;
    int selectedYear = Context.Request.Query.ContainsKey("year")
        ? int.Parse(Context.Request.Query["year"]!) : now.Year;

    // Seçili aya göre filtrele
    var filtered = Model
        .Where(t => t.Date.Month == selectedMonth && t.Date.Year == selectedYear)
        .OrderByDescending(t => t.Date)
        .ToList();

    // Özet
    decimal monthIncome = filtered.Where(t => t.Type == "Income").Sum(t => t.Amount);
    decimal monthExpense = filtered.Where(t => t.Type == "Expense").Sum(t => t.Amount);
    decimal monthBalance = monthIncome - monthExpense;

    // Önceki/sonraki ay
    var selectedDate = new DateTime(selectedYear, selectedMonth, 1);
    var prevDate = selectedDate.AddMonths(-1);
    var nextDate = selectedDate.AddMonths(1);
    bool isCurrentMonth = selectedMonth == now.Month && selectedYear == now.Year;

    // Günlere göre grupla
    var grouped = filtered
        .GroupBy(t => t.Date.Date)
        .OrderByDescending(g => g.Key)
        .ToList();

    string MonthName(DateTime d) => d.ToString("MMMM yyyy", culture);
    string DayLabel(DateTime d)
    {
        if (d.Date == now.Date) return "Bugün";
        if (d.Date == now.Date.AddDays(-1)) return "Dün";
        return d.ToString("dd MMMM, dddd", culture);
    }
}

<style>
    .month-nav {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 20px;
        margin-bottom: 24px;
    }

    .month-nav-btn {
        width: 36px; height: 36px;
        border-radius: 10px;
        background: white;
        border: 1.5px solid #e5e7eb;
        display: flex; align-items: center; justify-content: center;
        color: #374151; font-size: 16px;
        cursor: pointer;
        transition: all 0.18s;
        text-decoration: none;
    }

    .month-nav-btn:hover {
        background: #1AAFA3;
        border-color: #1AAFA3;
        color: white;
    }

    .month-nav-btn.disabled {
        opacity: 0.3;
        pointer-events: none;
    }

    .month-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        min-width: 180px;
        text-align: center;
    }

    .summary-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 24px;
    }

    .summary-card {
        background: white;
        border-radius: 14px;
        padding: 16px 20px;
        border: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .summary-card-label {
        font-size: 12px;
        color: #6b7280;
        margin-bottom: 4px;
    }

    .summary-card-amount {
        font-size: 22px;
        font-weight: 700;
    }

    .summary-card-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
    }

    /* Filtre bar */
    .filter-bar {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
        align-items: center;
    }

    .filter-search {
        flex: 1;
        min-width: 200px;
        padding: 9px 14px 9px 36px;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 14px;
        background: white;
        position: relative;
    }

    .filter-search:focus {
        outline: none;
        border-color: #1AAFA3;
        box-shadow: 0 0 0 3px rgba(26,175,163,0.1);
    }

    .search-wrapper {
        position: relative;
        flex: 1;
    }

    .search-wrapper i {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #9ca3af;
        font-size: 14px;
    }

    .filter-btn {
        padding: 9px 16px;
        border-radius: 10px;
        border: 1.5px solid #e5e7eb;
        background: white;
        font-size: 13px;
        font-weight: 500;
        color: #374151;
        cursor: pointer;
        transition: all 0.18s;
    }

    .filter-btn.active {
        background: #1AAFA3;
        border-color: #1AAFA3;
        color: white;
    }

    .filter-btn:hover:not(.active) {
        border-color: #1AAFA3;
        color: #1AAFA3;
    }

    /* Gün grubu */
    .day-group {
        margin-bottom: 16px;
    }

    .day-label {
        font-size: 12px;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        padding: 0 4px;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .day-label::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #f3f4f6;
    }

    .tx-card {
        background: white;
        border-radius: 12px;
        border: 1px solid #f3f4f6;
        padding: 12px 16px;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 14px;
        transition: box-shadow 0.18s;
    }

    .tx-card:hover {
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        border-color: #e5e7eb;
    }

    .tx-icon {
        width: 40px; height: 40px;
        border-radius: 10px;
        background: #f3f4f6;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }

    .tx-info { flex: 1; min-width: 0; }

    .tx-name {
        font-size: 14px;
        font-weight: 600;
        color: #111827;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .tx-meta {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 2px;
    }

    .tx-amount {
        font-size: 15px;
        font-weight: 700;
        flex-shrink: 0;
        text-align: right;
    }

    .tx-amount.income { color: #10b981; }
    .tx-amount.expense { color: #ef4444; }

    .tx-original {
        font-size: 11px;
        color: #9ca3af;
        display: block;
    }

    .tx-actions {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
        opacity: 0;
        transition: opacity 0.18s;
    }

    .tx-card:hover .tx-actions { opacity: 1; }

    .tx-action-btn {
        width: 30px; height: 30px;
        border-radius: 8px;
        border: 1.5px solid #e5e7eb;
        background: white;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.15s;
        text-decoration: none;
        color: #6b7280;
    }

    .tx-action-btn:hover.edit { border-color: #1AAFA3; color: #1AAFA3; background: #f0fdf4; }
    .tx-action-btn:hover.delete { border-color: #ef4444; color: #ef4444; background: #fef2f2; }

    .empty-month {
        text-align: center;
        padding: 60px 24px;
        color: #9ca3af;
    }

    .empty-month-icon { font-size: 48px; margin-bottom: 12px; }
    .empty-month-title { font-size: 16px; font-weight: 600; color: #6b7280; margin-bottom: 6px; }
    .empty-month-sub { font-size: 14px; }

    @@media (max-width: 640px) {
        .summary-cards { grid-template-columns: 1fr; }
        .tx-actions { opacity: 1; }
    }
</style>

<!-- Ay Navigasyonu -->
<div class="month-nav">
    <a class="month-nav-btn" href="/Transaction/Index?month=@prevDate.Month&year=@prevDate.Year">
        <i class="bi bi-chevron-left"></i>
    </a>
    <div class="month-title">@MonthName(selectedDate)</div>
    <a class="month-nav-btn @(isCurrentMonth ? "disabled" : "")"
       href="/Transaction/Index?month=@nextDate.Month&year=@nextDate.Year">
        <i class="bi bi-chevron-right"></i>
    </a>
</div>

<!-- Özet Kartlar -->
<div class="summary-cards">
    <div class="summary-card">
        <div>
            <div class="summary-card-label">Gelir</div>
            <div class="summary-card-amount" style="color: #10b981;">+₺@monthIncome.ToString("N2")</div>
        </div>
        <div class="summary-card-icon" style="background: #ecfdf5;">
            <i class="bi bi-arrow-down-circle" style="color: #10b981;"></i>
        </div>
    </div>
    <div class="summary-card">
        <div>
            <div class="summary-card-label">Gider</div>
            <div class="summary-card-amount" style="color: #ef4444;">-₺@monthExpense.ToString("N2")</div>
        </div>
        <div class="summary-card-icon" style="background: #fef2f2;">
            <i class="bi bi-arrow-up-circle" style="color: #ef4444;"></i>
        </div>
    </div>
    <div class="summary-card">
        <div>
            <div class="summary-card-label">Net Bakiye</div>
            <div class="summary-card-amount" style="color: @(monthBalance >= 0 ? "#1AAFA3" : "#ef4444");">
                @(monthBalance >= 0 ? "+" : "")₺@monthBalance.ToString("N2")
            </div>
        </div>
        <div class="summary-card-icon" style="background: #f0fdf4;">
            <i class="bi bi-wallet2" style="color: #1AAFA3;"></i>
        </div>
    </div>
</div>

<!-- Filtre Bar -->
<div class="filter-bar">
    <div class="search-wrapper">
        <i class="bi bi-search"></i>
        <input type="text" class="filter-search" id="searchInput"
               placeholder="İşlem ara..." oninput="filterTransactions()" />
    </div>
    <button class="filter-btn active" onclick="setFilter('all', this)">Tümü</button>
    <button class="filter-btn" onclick="setFilter('Income', this)">💰 Gelir</button>
    <button class="filter-btn" onclick="setFilter('Expense', this)">💸 Gider</button>
</div>

<!-- İşlemler -->
<div id="transactionsList">
    @if (!grouped.Any())
    {
        <div class="empty-month">
            <div class="empty-month-icon">📭</div>
            <div class="empty-month-title">Bu ayda işlem yok</div>
            <div class="empty-month-sub">+ butonuyla yeni işlem ekleyebilirsin</div>
        </div>
    }
    else
    {
        foreach (var group in grouped)
        {
            <div class="day-group" data-day="@group.Key.ToString("yyyy-MM-dd")">
                <div class="day-label">@DayLabel(group.Key)</div>

                @foreach (var t in group)
                {
                    bool isIncome = t.Type == "Income";
                    bool hasFx = t.OriginalCurrency != "TRY" && t.OriginalCurrency != null;

                    <div class="tx-card"
                         data-type="@t.Type"
                         data-search="@((t.Description + " " + t.CategoryName).ToLower())">

                        <div class="tx-icon">@(t.CategoryIcon ?? "💳")</div>

                        <div class="tx-info">
                            <div class="tx-name">
                                @(string.IsNullOrEmpty(t.Description) ? t.CategoryName : t.Description)
                            </div>
                            <div class="tx-meta">
                                @t.CategoryName
                                @if (hasFx)
                                {
                                    <span class="ms-2" style="color: #1AAFA3;">
                                        @t.OriginalAmount?.ToString("N4") @t.OriginalCurrency
                                    </span>
                                }
                            </div>
                        </div>

                        <div class="tx-amount @(isIncome ? "income" : "expense")">
                            @(isIncome ? "+" : "-")₺@t.Amount.ToString("N2")
                            @if (hasFx)
                            {
                                <span class="tx-original">
                                    Kur: @t.ExchangeRate?.ToString("N4")
                                </span>
                            }
                        </div>

                        <div class="tx-actions">
                            <a href="/Transaction/Edit/@t.TransactionId"
                               class="tx-action-btn edit" title="Düzenle">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="/Transaction/Delete/@t.TransactionId"
                                  onsubmit="return confirm('Bu işlemi silmek istediğinize emin misiniz?')"
                                  style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="tx-action-btn delete" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@section Scripts {
    <script>
        let currentFilter = 'all';

        function setFilter(type, btn) {
            currentFilter = type;
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            filterTransactions();
        }

        function filterTransactions() {
            const search = document.getElementById('searchInput').value.toLowerCase();

            document.querySelectorAll('.tx-card').forEach(card => {
                const type = card.dataset.type;
                const searchText = card.dataset.search;

                const typeMatch = currentFilter === 'all' || type === currentFilter;
                const searchMatch = !search || searchText.includes(search);

                card.style.display = (typeMatch && searchMatch) ? 'flex' : 'none';
            });

            // Boş günleri gizle
            document.querySelectorAll('.day-group').forEach(group => {
                const visible = group.querySelectorAll('.tx-card[style=""],.tx-card:not([style])');
                const hasVisible = Array.from(group.querySelectorAll('.tx-card'))
                    .some(c => c.style.display !== 'none');
                group.style.display = hasVisible ? 'block' : 'none';
            });
        }
    </script>
}